+static void bbk9588_touch_apply_host_input(Bbk9588MachineState *board,
+                                           uint16_t raw_x,
+                                           uint16_t raw_y,
+                                           uint16_t x,
+                                           uint16_t y,
+                                           bool down)
+{
+    (void)x;
+    (void)y;
+    bbk9588_touch_set_state(board, raw_x, raw_y, down);
+}
+
+static bool bbk9588_key_gpio_bits(uint32_t key_code, hwaddr *offset,
+                                  uint32_t *mask)
+{
+    switch (key_code) {
+    case 10:
+        *offset = 0x100;
+        *mask = 0x40000000u;
+        return true;
+    case 5:
+        *offset = 0x100;
+        *mask = 0x10000000u;
+        return true;
+    case 7:
+        *offset = 0x100;
+        *mask = 0x08000000u;
+        return true;
+    case 6:
+        *offset = 0x100;
+        *mask = 0x20000000u;
+        return true;
+    case 9:
+        *offset = 0x200;
+        *mask = 0x08000000u;
+        return true;
+    case 4:
+        *offset = 0x300;
+        *mask = 0x00200000u;
+        return true;
+    default:
+        return false;
+    }
+}
+
+static bool bbk9588_key_gpio_set_state(Bbk9588MachineState *board,
+                                       uint32_t key_code, bool down)
+{
+    hwaddr offset = 0;
+    uint32_t mask = 0;
+    uint32_t *down_mask = NULL;
+    uint32_t *flag = NULL;
+    int main_irq = -1;
+    bool was_down;
+
+    if (!bbk9588_key_gpio_bits(key_code, &offset, &mask)) {
+        return false;
+    }
+
+    switch (offset) {
+    case 0x100:
+        down_mask = &board->key_gpio_down_100;
+        flag = &board->gpio_flag_100;
+        main_irq = 27;
+        break;
+    case 0x200:
+        down_mask = &board->key_gpio_down_200;
+        flag = &board->gpio_flag_200;
+        main_irq = 26;
+        break;
+    case 0x300:
+        down_mask = &board->key_gpio_down_300;
+        flag = &board->gpio_flag_300;
+        main_irq = 25;
+        break;
+    default:
+        return false;
+    }
+
+    was_down = (*down_mask & mask) != 0;
+    if (down) {
+        *down_mask |= mask;
+    } else {
+        *down_mask &= ~mask;
+    }
+    if (was_down != down) {
+        *flag |= mask;
+        if (main_irq >= 0) {
+            board->intc_pending_mask |= 1u << main_irq;
+            bbk9588_update_irq(board);
+        }
+        return true;
+    }
+    return false;
+}
+
+static void bbk9588_key_apply_host_input(Bbk9588MachineState *board,
+                                         uint32_t key_code, bool down)
+{
+    if (bbk9588_key_gpio_set_state(board, key_code & 0xff, down)) {
+        bbk9588_queue_input_event(board, BBK9588_EVENT_KIND_KEY,
+                                  key_code & 0xff, down ? 1 : 0, 0);
+    }
+}
+
+static void bbk9588_resource_pump_timer_cb(void *opaque)
+{
+    Bbk9588MachineState *board = opaque;
+
+    bbk9588_progress_trace_sample(board, 2);
+
+    bbk9588_resource_pump_schedule(board);
+}
+
+static uint32_t bbk9588_intc_read(Bbk9588MachineState *board, hwaddr offset)
+{
+    uint32_t value;
+
+    bbk9588_update_irq(board);
+
+    switch (offset) {
+    case 0x00:
+        value = board->intc_pending_mask & ~board->intc_mask;
+        break;
+    case 0x04:
+        value = board->intc_mask;
+        break;
+    case 0x10:
+        value = board->intc_pending_mask;
+        break;
+    default:
+        value = 0;
+        break;
+    }
+    board->intc_last_read_offset = (uint32_t)offset;
+    board->intc_last_read_value = value;
+    return value;
+}
+
+static void bbk9588_intc_write(Bbk9588MachineState *board, hwaddr offset,
+                               uint32_t value)
+{
+    uint32_t ack = value & 0xffffffffu;
+    int64_t now = qemu_clock_get_ms(QEMU_CLOCK_REALTIME);
+
+    board->intc_last_write_offset = (uint32_t)offset;
+    board->intc_last_write_value = (uint32_t)value;
+    switch (offset) {
+    case 0x08:
+        board->intc_mask |= value;
+        bbk9588_update_irq(board);
+        break;
+    case 0x0c:
+        board->intc_mask &= ~value;
+        bbk9588_update_irq(board);
+        break;
+    case 0x10:
+        board->intc_pending_mask &= ~ack;
+        if (ack & (1u << 22)) {
+            board->sysctrl_wake_pending = false;
+        }
+        if (ack != 0) {
+            board->intc_ack_count++;
+        }
+        for (unsigned ch = 0; ch < BBK9588_TCU_CHANNELS; ch++) {
+            int irq = bbk9588_tcu_channel_irq(ch);
+
+            if (irq >= 0 && (ack & (1u << irq))) {
+                board->tcu_pending_mask &= ~(1u << ch);
+                board->intc_ack_tcu_count++;
+                board->tcu_deadline_ms[ch] =
+                    now + (board->tcu_channel_period_ms[ch] ?
+                           board->tcu_channel_period_ms[ch] :
+                           board->tcu_period_ms);
+            }
+        }
+        if (ack & (1u << 24)) {
+            bbk9588_irq24_schedule(board);
+        }
+        if (ack & (1u << BBK9588_UART_IRQ)) {
+            bbk9588_uart_sync_irq(board);
+        }
+        bbk9588_update_irq(board);
+        bbk9588_tcu_schedule(board);
+        break;
+    default:
+        break;
+    }
+}
+
+static void bbk9588_tcu_write(Bbk9588MachineState *board, hwaddr offset,
+                              uint32_t value)
+{
+    int64_t now = qemu_clock_get_ms(QEMU_CLOCK_REALTIME);
+    unsigned ch;
+
+    board->tcu_last_write_offset = (uint32_t)offset;
+    board->tcu_last_write_value = (uint32_t)value;
+    switch (offset) {
+    case 0x14: /* TESR: timer enable set */
+        value &= BBK9588_TCU_MASK;
+        for (ch = 0; ch < BBK9588_TCU_CHANNELS; ch++) {
+            uint32_t bit = 1u << ch;
+
+            if ((value & bit) && !(board->tcu_enabled_mask & bit)) {
+                board->tcu_deadline_ms[ch] =
+                    now + (board->tcu_channel_period_ms[ch] ?
+                           board->tcu_channel_period_ms[ch] :
+                           board->tcu_period_ms);
+            }
+        }
+        board->tcu_enabled_mask |= value;
+        bbk9588_tcu_schedule(board);
+        break;
+    case 0x18: /* TECR: timer enable clear */
+        value &= BBK9588_TCU_MASK;
+        board->tcu_enabled_mask &= ~value;
+        for (ch = 0; ch < BBK9588_TCU_CHANNELS; ch++) {
+            if (value & (1u << ch)) {
+                board->tcu_deadline_ms[ch] = 0;
+                board->tcu_pending_mask &= ~(1u << ch);
+            }
+        }
+        bbk9588_update_irq(board);
+        bbk9588_tcu_schedule(board);
+        break;
+    case 0x24: /* TFSR: timer flag set */
+        board->tcu_pending_mask |= value & BBK9588_TCU_MASK;
+        bbk9588_update_irq(board);
+        break;
+    case 0x28: /* TFCR: timer flag clear */
+        value &= BBK9588_TCU_MASK;
+        board->tcu_pending_mask &= ~value;
+        for (ch = 0; ch < BBK9588_TCU_CHANNELS; ch++) {
+            if (value & (1u << ch)) {
+                board->tcu_deadline_ms[ch] =
+                    now + (board->tcu_channel_period_ms[ch] ?
+                           board->tcu_channel_period_ms[ch] :
+                           board->tcu_period_ms);
+            }
+        }
+        bbk9588_update_irq(board);
+        bbk9588_tcu_schedule(board);
+        break;
+    case 0x34: /* TMSR: timer mask set */
+        board->tcu_irq_mask |= value & BBK9588_TCU_MASK;
+        bbk9588_update_irq(board);
+        break;
+    case 0x38: /* TMCR: timer mask clear */
+        board->tcu_irq_mask &= ~(value & BBK9588_TCU_MASK);
+        bbk9588_update_irq(board);
+        bbk9588_tcu_schedule(board);
+        break;
+    default:
+        if (offset >= 0x40 &&
+            offset < 0x40 + BBK9588_TCU_CHANNELS * 0x10 &&
+            (((offset - 0x40) & 0x0f) == 0x00 ||
+             ((offset - 0x40) & 0x0f) == 0x04)) {
+            unsigned channel = (offset - 0x40) / 0x10;
+
+            bbk9588_tcu_update_period(board, channel, value);
+            bbk9588_tcu_schedule(board);
+        }
+        break;
+    }
+}
+
+static void bbk9588_lcd_write(Bbk9588MachineState *board, hwaddr offset,
+                              uint32_t value)
+{
+    switch (offset) {
+    case 0x0c:
+        board->lcd_irq_status &= ~(value & BBK9588_LCD_STATUS_FRAME_DONE);
+        break;
+    case 0x00:
+    case 0x04:
+    case 0x08:
+        /*
+         * Keep the controller ready while firmware programs timing/control
+         * registers, but do not synthesize a frame-done edge until DMA/frame
+         * address registers point at guest RAM.
+         */
+        board->lcd_status |= 0x80u;
+        break;
+    default:
+        break;
+    }
+}
+
+static void bbk9588_nand_fill_read(Bbk9588NandState *nand,
+                                   const uint8_t *data, size_t len)
+{
+    memset(nand->read_buffer, 0xff, sizeof(nand->read_buffer));
+    memcpy(nand->read_buffer, data, MIN(len, sizeof(nand->read_buffer)));
+    nand->read_index = 0;
+}
+
+static void bbk9588_nand_prepare_erased_page(Bbk9588NandState *nand)
+{
+    memset(nand->read_buffer, 0xff, sizeof(nand->read_buffer));
+    nand->read_index = 0;
+}
+
+static bool bbk9588_nand_data_region_is_blank(const uint8_t *data,
+                                              gsize size,
+                                              uint32_t stride,
+                                              uint32_t page,
+                                              uint32_t column,
+                                              uint32_t len)
+{
+    uint64_t offset = (uint64_t)page * stride + column;
+    if (!data || column >= BBK9588_NAND_PAGE_SIZE ||
+        offset + len > size) {
+        return true;
+    }
+
+    for (uint32_t i = 0; i < len; i++) {
+        if (data[offset + i] != 0xffu) {
+            return false;
+        }
+    }
+    return true;
+}
+
+static bool bbk9588_nand_page_region_is_blank(Bbk9588NandState *nand,
+                                              uint32_t page,
+                                              uint32_t column,
+                                              uint32_t len)
+{
+    return bbk9588_nand_data_region_is_blank(
+        nand ? nand->data : NULL,
+        nand ? nand->size : 0,
+        nand ? bbk9588_nand_page_stride(nand) : BBK9588_NAND_STRIDE,
+        page, column, len);
+}
+
+static void bbk9588_nand_build_ftl_map(Bbk9588NandState *nand)
+{
+    enum { pages_per_block = 64 };
+    uint32_t stride = bbk9588_nand_page_stride(nand);
+    uint64_t page_count;
+    uint32_t block_count;
+
+    if (!nand || !nand->data || nand->ftl_map_valid ||
+        stride < BBK9588_NAND_STRIDE) {
+        return;
+    }
+
+    page_count = nand->size / stride;
+    block_count = page_count / pages_per_block;
+    if (block_count == 0 || block_count > 0x10000) {
+        nand->ftl_map_valid = true;
+        return;
+    }
+
+    nand->ftl_logical_to_physical = g_new(uint32_t, block_count);
+    nand->ftl_block_seq = g_new0(uint16_t, block_count);
+    nand->ftl_block_count = block_count;
+    for (uint32_t i = 0; i < block_count; i++) {
+        nand->ftl_logical_to_physical[i] = UINT32_MAX;
+    }
+
+    for (uint32_t physical = 0; physical < block_count; physical++) {
+        uint64_t oob = (uint64_t)physical * pages_per_block * stride +
+                       BBK9588_NAND_PAGE_SIZE;
+        uint16_t seq;
+        uint32_t logical;
+
+        if (oob + BBK9588_NAND_SPARE_SIZE > nand->size) {
+            break;
+        }
+
+        seq = bbk9588_lduw_le(nand->data + oob +
+                              BBK9588_NAND_SPARE_SIZE - 6);
+        logical = bbk9588_ldl_le(nand->data + oob +
+                                 BBK9588_NAND_SPARE_SIZE - 4) & 0xffffu;
+        if (seq == 0xffffu || logical >= block_count) {
+            continue;
+        }
+        if (nand->ftl_logical_to_physical[logical] == UINT32_MAX ||
+            seq >= nand->ftl_block_seq[logical]) {
+            nand->ftl_logical_to_physical[logical] = physical;
+            nand->ftl_block_seq[logical] = seq;
+        }
+    }
+
+    nand->ftl_map_valid = true;
+}
+
+static uint32_t bbk9588_nand_translate_data_page(Bbk9588NandState *nand,
+                                                 uint32_t page,
+                                                 bool *translated)
+{
+    enum { pages_per_block = 64 };
+    uint32_t logical_block = page / pages_per_block;
+    uint32_t page_in_block = page % pages_per_block;
+    uint32_t physical_block;
+
+    if (translated) {
+        *translated = false;
+    }
+    if (!nand) {
+        return page;
+    }
+    bbk9588_nand_build_ftl_map(nand);
+    if (!nand->ftl_map_valid ||
+        logical_block >= nand->ftl_block_count ||
+        !nand->ftl_logical_to_physical) {
+        return page;
+    }
+
+    physical_block = nand->ftl_logical_to_physical[logical_block];
+    if (physical_block == UINT32_MAX ||
+        physical_block >= nand->ftl_block_count) {
+        return page;
+    }
+    if (translated && physical_block != logical_block) {
+        *translated = true;
+    }
+    return physical_block * pages_per_block + page_in_block;
+}
+
+static void bbk9588_nand_prepare_page_read(Bbk9588NandState *nand)
+{
+    uint32_t column;
+    uint32_t page;
+    uint32_t requested_page;
+    uint32_t pc = 0;
+    uint64_t offset;
+    uint32_t stride = bbk9588_nand_page_stride(nand);
+    size_t copy_len = 0;
+    const uint8_t *read_data = nand->data;
+    gsize read_size = nand->size;
+    bool request_blank = false;
+    bool final_blank = true;
+    uint32_t source = BBK9588_NAND_READ_SOURCE_RUNTIME;
+
+    if (nand->addr_count < 5) {
+        bbk9588_nand_prepare_erased_page(nand);
+        return;
+    }
+
+    column = nand->addr[0] | (nand->addr[1] << 8);
+    page = nand->addr[2] |
+           (nand->addr[3] << 8) |
+           (nand->addr[4] << 16);
+    if (bbk9588_active_board && bbk9588_active_board->cpu) {
+        pc = bbk9588_active_board->cpu->env.active_tc.PC & 0xffffffffu;
+    }
+    if (column == 0 &&
+        nand->last_oob_page_valid &&
+        page != nand->last_oob_page &&
+        pc == 0x809066c0u) {
+        page = nand->last_oob_page;
+    }
+    if (column >= BBK9588_NAND_PAGE_SIZE && pc == 0x8090674cu) {
+        nand->last_oob_page = page;
+        nand->last_oob_page_valid = true;
+    }
+    requested_page = page;
+    nand->read_page = requested_page;
+    nand->read_column = column;
+    if (column < BBK9588_NAND_PAGE_SIZE) {
+        request_blank = bbk9588_nand_page_region_is_blank(
+            nand, page, column, BBK9588_NAND_PAGE_SIZE - column);
+    }
+    offset = (uint64_t)page * stride + column;
+
+    memset(nand->read_buffer, 0xff, sizeof(nand->read_buffer));
+    if (read_data && column < stride && offset < read_size) {
+        copy_len = MIN((uint64_t)sizeof(nand->read_buffer),
+                       (uint64_t)read_size - offset);
+        memcpy(nand->read_buffer, read_data + offset, copy_len);
+    }
+    if (column < BBK9588_NAND_PAGE_SIZE) {
+        final_blank = bbk9588_nand_data_region_is_blank(
+            read_data, read_size, stride, page, column,
+            BBK9588_NAND_PAGE_SIZE - column);
+        if (final_blank && nand->initial_data &&
+            !bbk9588_nand_data_region_is_blank(
+                nand->initial_data, nand->initial_size, stride, page, column,
+                BBK9588_NAND_PAGE_SIZE - column)) {
+            read_data = nand->initial_data;
+            read_size = nand->initial_size;
+            offset = (uint64_t)page * stride + column;
+            memset(nand->read_buffer, 0xff, sizeof(nand->read_buffer));
+            if (column < stride && offset < read_size) {
+                copy_len = MIN((uint64_t)sizeof(nand->read_buffer),
+                               (uint64_t)read_size - offset);
+                memcpy(nand->read_buffer, read_data + offset, copy_len);
+            } else {
+                copy_len = 0;
+            }
+            final_blank = false;
+            source = (source & ~BBK9588_NAND_READ_SOURCE_RUNTIME) |
+                     BBK9588_NAND_READ_SOURCE_INITIAL;
+        }
+    }
+    if (request_blank) {
+        source |= BBK9588_NAND_READ_REQUEST_BLANK;
+    }
+    if (final_blank) {
+        source |= BBK9588_NAND_READ_FINAL_BLANK;
+    }
+    if (bbk9588_active_board &&
+        bbk9588_active_board->storage_trace_enabled &&
+        column < BBK9588_NAND_PAGE_SIZE) {
+        bbk9588_storage_trace_record(
+            BBK9588_STORAGE_TRACE_NAND_READ | requested_page,
+            ((source & 0xffu) << 24) | (page & 0x00ffffffu),
+            copy_len >= 4 ? bbk9588_ldl_le(nand->read_buffer) : 0xffffffffu);
+        bbk9588_storage_trace_record(
+            BBK9588_STORAGE_TRACE_NAND_READ |
+            BBK9588_STORAGE_TRACE_NAND_DETAIL |
+            (requested_page & 0x03ffffffu),
+            column,
+            pc);
+        if ((requested_page >= 0x2c2f0u && requested_page <= 0x2c320u) ||
+            (page >= 0x2c2f0u && page <= 0x2c320u)) {
+            uint8_t guest_cache[32];
+            uint8_t guest_obj[0x60];
+
+            error_report("bbk9588-nand-read req=0x%06x final=0x%06x "
+                         "col=0x%03x pc=0x%08x source=0x%02x first=%08x "
+                         "bytes=%02x%02x%02x%02x%02x%02x%02x%02x",
+                         requested_page, page, column, pc, source & 0xffu,
+                         copy_len >= 4 ? bbk9588_ldl_le(nand->read_buffer)
+                                       : 0xffffffffu,
+                         nand->read_buffer[0], nand->read_buffer[1],
+                         nand->read_buffer[2], nand->read_buffer[3],
+                         nand->read_buffer[4], nand->read_buffer[5],
+                         nand->read_buffer[6], nand->read_buffer[7]);
+            if (requested_page == 0x2c30du) {
+                cpu_physical_memory_read(0x00b714cc, guest_cache,
+                                         sizeof(guest_cache));
+                cpu_physical_memory_read(0x0095a26c, guest_obj,
+                                         sizeof(guest_obj));
+                error_report("bbk9588-guest-cache va=0x80b714cc "
+                             "bytes=%02x%02x%02x%02x%02x%02x%02x%02x"
+                             "%02x%02x%02x%02x%02x%02x%02x%02x "
+                             "obj20=%08x obj24=%08x obj44=%08x "
+                             "obj48=%04x obj4a=%04x obj50=%08x obj54=%08x",
+                             guest_cache[0], guest_cache[1], guest_cache[2],
+                             guest_cache[3], guest_cache[4], guest_cache[5],
+                             guest_cache[6], guest_cache[7], guest_cache[8],
+                             guest_cache[9], guest_cache[10], guest_cache[11],
+                             guest_cache[12], guest_cache[13],
+                             guest_cache[14], guest_cache[15],
+                             bbk9588_ldl_le(guest_obj + 0x20),
+                             bbk9588_ldl_le(guest_obj + 0x24),
+                             bbk9588_ldl_le(guest_obj + 0x44),
+                             bbk9588_lduw_le(guest_obj + 0x48),
+                             bbk9588_lduw_le(guest_obj + 0x4a),
+                             bbk9588_ldl_le(guest_obj + 0x50),
+                             bbk9588_ldl_le(guest_obj + 0x54));
+                cpu_physical_memory_read(0x003695b8, guest_cache,
+                                         sizeof(guest_cache));
+                error_report("bbk9588-cluster-cache va=0x803695b8 "
+                             "bytes=%02x%02x%02x%02x%02x%02x%02x%02x"
+                             "%02x%02x%02x%02x%02x%02x%02x%02x",
+                             guest_cache[0], guest_cache[1], guest_cache[2],
+                             guest_cache[3], guest_cache[4], guest_cache[5],
+                             guest_cache[6], guest_cache[7], guest_cache[8],
+                             guest_cache[9], guest_cache[10], guest_cache[11],
+                             guest_cache[12], guest_cache[13],
+                             guest_cache[14], guest_cache[15]);
+            }
+        }
+    }
+    nand->read_index = 0;
+}
+
+static uint32_t bbk9588_nand_page_from_addr(Bbk9588NandState *nand)
+{
+    if (nand->addr_count < 5) {
+        return 0;
+    }
+    return nand->addr[2] |
+           (nand->addr[3] << 8) |
+           (nand->addr[4] << 16);
+}
+
+static uint32_t bbk9588_nand_column_from_addr(Bbk9588NandState *nand)
+{
+    if (nand->addr_count < 2) {
+        return 0;
+    }
+    return nand->addr[0] | (nand->addr[1] << 8);
+}
+
+static uint32_t bbk9588_nand_row_from_addr(Bbk9588NandState *nand)
+{
+    uint32_t row = 0;
+
+    for (unsigned i = 0; i < MIN(nand->addr_count, 3u); i++) {
+        row |= (uint32_t)nand->addr[i] << (i * 8);
+    }
+    return row;
+}
+
+static void bbk9588_nand_bch_start(Bbk9588NandState *nand)
+{
+    if (!nand) {
+        return;
+    }
+
+    nand->bch_status = 0;
+    nand->bch_busy_reads = 1;
+}
+
+static uint32_t bbk9588_nand_bch_read_status(Bbk9588MachineState *board)
+{
+    Bbk9588NandState *nand = board ? board->nand_dev : NULL;
+
+    if (!nand) {
+        return BBK9588_BCH_STATUS_READY;
+    }
+    if (nand->bch_busy_reads > 0) {
+        nand->bch_busy_reads--;
+        if (nand->bch_busy_reads == 0) {
+            nand->bch_status = BBK9588_BCH_STATUS_READY;
+        }
+        return 0;
+    }
+    return nand->bch_status;
+}
+
+static void bbk9588_nand_bch_ack_status(Bbk9588MachineState *board,
+                                        uint32_t value)
+{
+    Bbk9588NandState *nand = board ? board->nand_dev : NULL;
+
+    if (!nand) {
+        return;
+    }
+    nand->bch_status &= ~value;
+}
+
+static void bbk9588_nand_begin_program(Bbk9588NandState *nand)
+{
+    memset(nand->program_buffer, 0xff, sizeof(nand->program_buffer));
+    nand->program_len = 0;
+    nand->program_page = 0;
+    nand->program_column = 0;
+    nand->program_has_data = false;
+    nand->program_page_valid = false;
+}
+
+static void bbk9588_nand_append_program_data(Bbk9588NandState *nand,
+                                             uint64_t value, unsigned size)
+{
+    unsigned max_size = MIN(size, 4u);
+
+    if (nand->cmd != 0x80 && nand->cmd != 0x85) {
+        return;
+    }
+    for (unsigned i = 0; i < max_size; i++) {
+        if (nand->program_column >= sizeof(nand->program_buffer)) {
+            return;
+        }
+        nand->program_buffer[nand->program_column++] =
+            (value >> (i * 8)) & 0xff;
+        nand->program_has_data = true;
+        if (nand->program_column > nand->program_len) {
+            nand->program_len = nand->program_column;
+        }
+    }
+}
+
+static void bbk9588_nand_backend_update(Bbk9588NandState *nand,
+                                         uint64_t offset, uint64_t len)
+{
+    uint64_t write_start;
+    uint64_t write_end;
+    BlockBackend *blk = nand->blk;
+    int ret;
+
+    if (!blk || !blk_is_writable(blk) || len == 0) {
+        return;
+    }
+
+    write_start = QEMU_ALIGN_DOWN(offset, BDRV_SECTOR_SIZE);
+    write_end = QEMU_ALIGN_UP(offset + len, BDRV_SECTOR_SIZE);
+    if (write_start >= nand->size) {
+        return;
+    }
+    if (write_end > nand->size) {
+        write_end = nand->size;
+    }
+
+    ret = blk_pwrite(blk, write_start, write_end - write_start,
+                     nand->data + write_start, 0);
+    if (ret < 0) {
+        error_report("bbk9588: could not update NAND offset=0x%" PRIx64
+                     " length=0x%" PRIx64 ": %s",
+                     write_start, write_end - write_start, strerror(-ret));
+    }
+}
+
+static bool bbk9588_nand_page_is_fat_protected(uint32_t page)
+{
+    return page >= BBK9588_NAND_FAT_PROTECT_START_PAGE &&
+           page < BBK9588_NAND_FAT_PROTECT_END_PAGE;
+}
+
+static void bbk9588_nand_commit_program(Bbk9588NandState *nand)
+{
+    uint64_t page_offset;
+    uint32_t column;
+    uint32_t page;
+    uint32_t stride = bbk9588_nand_page_stride(nand);
+    unsigned limit;
+
+    if (!nand->data || !nand->program_page_valid ||
+        !nand->program_has_data) {
+        nand->program_len = 0;
+        nand->program_has_data = false;
+        return;
+    }
+
+    page = nand->program_page;
+    column = 0;
+    if (bbk9588_nand_page_is_fat_protected(page)) {
+        if (bbk9588_active_board &&
+            bbk9588_active_board->storage_trace_enabled) {
+            error_report("bbk9588-nand-program-protect page=0x%06x",
+                         page);
+        }
+        nand->program_len = 0;
+        nand->program_has_data = false;
+        return;
+    }
+    page_offset = (uint64_t)page * stride;
+    if (page_offset >= nand->size || column >= stride) {
+        nand->program_len = 0;
+        nand->program_has_data = false;
+        return;
+    }
+
+    limit = MIN(nand->program_len, stride - column);
+    if (page_offset + column + limit > nand->size) {
+        limit = nand->size - page_offset - column;
+    }
+    for (unsigned i = 0; i < limit; i++) {
+        nand->data[page_offset + column + i] &=
+            nand->program_buffer[column + i];
+    }
+    bbk9588_nand_backend_update(nand, page_offset + column, limit);
+    if (bbk9588_active_board) {
+        bbk9588_active_board->nand_program_count++;
+        bbk9588_active_board->nand_last_page = page;
+        bbk9588_active_board->nand_last_column = column;
+    }
+    if (bbk9588_active_board &&
+        bbk9588_active_board->storage_trace_enabled &&
+        column < BBK9588_NAND_PAGE_SIZE) {
+        uint32_t first_word = 0xffffffffu;
+
+        if (limit >= 4) {
+            first_word = (uint32_t)nand->data[page_offset + column] |
+                         ((uint32_t)nand->data[page_offset + column + 1] << 8) |
+                         ((uint32_t)nand->data[page_offset + column + 2] << 16) |
+                         ((uint32_t)nand->data[page_offset + column + 3] << 24);
+        }
+        bbk9588_storage_trace_record(BBK9588_STORAGE_TRACE_NAND_PROGRAM | page,
+                                     column, first_word);
+    }
+    if (page == BBK9588_NAND_TARGET_PAGE &&
+        column < BBK9588_NAND_PAGE_SIZE) {
+        uint32_t first_word = 0xffffffffu;
+
+        if (limit >= 4) {
+            first_word = (uint32_t)nand->data[page_offset + column] |
+                         ((uint32_t)nand->data[page_offset + column + 1] << 8) |
+                         ((uint32_t)nand->data[page_offset + column + 2] << 16) |
+                         ((uint32_t)nand->data[page_offset + column + 3] << 24);
+        }
+        bbk9588_nand_target_trace_record(
+            BBK9588_NAND_TARGET_EVENT_PROGRAM, page, column, first_word);
+    }
+    if (bbk9588_active_board) {
+        bbk9588_nand_raise_ready(bbk9588_active_board);
+    }
+    nand->program_page = page;
+    nand->program_column = column;
+    nand->program_len = 0;
+    nand->program_has_data = false;
+    nand->ftl_map_valid = false;
+    nand->fat16_layout_valid = false;
+}
+
+static void bbk9588_nand_commit_erase(Bbk9588NandState *nand)
+{
+    enum { pages_per_block = 64 };
+    uint32_t row;
+    uint32_t block_start;
+
+    if (!nand->data || nand->addr_count < 2) {
+        return;
+    }
+    row = bbk9588_nand_row_from_addr(nand);
+    block_start = row & ~(pages_per_block - 1);
+    if (bbk9588_nand_page_is_fat_protected(block_start) ||
+        bbk9588_nand_page_is_fat_protected(block_start + pages_per_block - 1)) {
+        if (bbk9588_active_board &&
+            bbk9588_active_board->storage_trace_enabled) {
+            error_report("bbk9588-nand-erase-protect block=0x%06x row=0x%06x",
+                         block_start, row);
+        }
+        if (bbk9588_active_board) {
+            bbk9588_nand_raise_ready(bbk9588_active_board);
+        }
+        return;
+    }
+    for (unsigned page = block_start; page < block_start + pages_per_block; page++) {
+        uint32_t stride = bbk9588_nand_page_stride(nand);
+        uint64_t offset = (uint64_t)page * stride;
+        uint64_t len;
+
+        if (offset >= nand->size) {
+            break;
+        }
+        len = MIN((uint64_t)stride, (uint64_t)nand->size - offset);
+        memset(nand->data + offset, 0xff, len);
+        bbk9588_nand_backend_update(nand, offset, len);
+    }
+    if (bbk9588_active_board &&
+        bbk9588_active_board->storage_trace_enabled) {
+        bbk9588_storage_trace_record(
+            BBK9588_STORAGE_TRACE_NAND_ERASE | block_start,
+            pages_per_block,
+            0xffffffffu);
+    }
+    if (block_start == BBK9588_NAND_TARGET_BLOCK) {
+        bbk9588_nand_target_trace_record(
+            BBK9588_NAND_TARGET_EVENT_ERASE, block_start, row,
+            pages_per_block);
+    }
+    if (bbk9588_active_board) {
+        bbk9588_active_board->nand_erase_count++;
+        bbk9588_active_board->nand_last_page = row;
+        bbk9588_active_board->nand_last_block = block_start;
+        bbk9588_nand_raise_ready(bbk9588_active_board);
+    }
+    nand->ftl_map_valid = false;
+    nand->fat16_layout_valid = false;
+}
+
+static uint32_t bbk9588_nand_read_data(Bbk9588NandState *nand,
+                                       unsigned size)
+{
+    uint32_t value = 0xffffffffu;
+    unsigned max_size = MIN(size, 4u);
+
+    for (unsigned i = 0; i < max_size; i++) {
+        uint8_t byte = 0xff;
+        unsigned index = nand->read_index;
+
+        if (index < sizeof(nand->read_buffer)) {
+            byte = nand->read_buffer[index];
+        }
+        if (bbk9588_active_board &&
+            bbk9588_active_board->storage_trace_enabled &&
+            ((nand->read_page == 0x2c30cu &&
+              index >= 0x6b8u && index < 0x6c0u) ||
+             (nand->read_page == 0x2c30fu &&
+              index >= 0x598u && index < 0x5a0u))) {
+            uint32_t pc = 0;
+            uint32_t s0 = 0;
+            if (bbk9588_active_board->cpu) {
+                pc = bbk9588_active_board->cpu->env.active_tc.PC &
+                     0xffffffffu;
+                s0 = bbk9588_active_board->cpu->env.active_tc.gpr[16] &
+                     0xffffffffu;
+            }
+            error_report("bbk9588-nand-data page=0x%06x col=0x%03x "
+                         "idx=0x%03x byte=%02x pc=0x%08x s0=0x%08x",
+                         nand->read_page, nand->read_column, index, byte,
+                         pc, s0);
+        }
+        nand->read_index++;
+        value = (value & ~(0xffu << (i * 8))) | ((uint32_t)byte << (i * 8));
+    }
+    return value;
+}
+
+static uint64_t bbk9588_nand_read(Bbk9588NandState *nand,
+                                  hwaddr offset, unsigned size)
+{
+    switch (offset) {
+    case 0x00000:
+        return bbk9588_nand_read_data(nand, size);
+    default:
+        return 0xffffffffu;
+    }
+}
+
+static void bbk9588_nand_command(Bbk9588NandState *nand, uint8_t command)
+{
+    static const uint8_t status[] = { 0x40, 0xff, 0xff, 0xff };
+    Bbk9588MachineState *board = bbk9588_active_board;
+
+    nand->cmd = command;
+    if (board) {
+        board->nand_last_cmd = command;
+    }
+    if (command == 0x00 || command == 0x60 || command == 0x80 ||
+        command == 0x85 ||
+        command == 0x90 || command == 0xff) {
+        nand->addr_count = 0;
+        nand->read_index = 0;
+    }
+
+    switch (command) {
+    case 0x30:
+        bbk9588_nand_prepare_page_read(nand);
+        nand->busy_reads = 1;
+        bbk9588_nand_bch_start(nand);
+        if (board) {
+            board->nand_page_read_count++;
+            board->nand_last_page = bbk9588_nand_page_from_addr(nand);
+            board->nand_last_column = bbk9588_nand_column_from_addr(nand);
+            bbk9588_nand_raise_ready(board);
+        }
+        break;
+    case 0x35:
+        bbk9588_nand_prepare_page_read(nand);
+        memcpy(nand->program_buffer, nand->read_buffer,
+               sizeof(nand->program_buffer));
+        nand->program_len = sizeof(nand->program_buffer);
+        nand->program_column = 0;
+        nand->program_has_data = true;
+        nand->program_page_valid = false;
+        nand->busy_reads = 1;
+        bbk9588_nand_bch_start(nand);
+        if (board) {
+            board->nand_page_read_count++;
+            board->nand_last_page = bbk9588_nand_page_from_addr(nand);
+            board->nand_last_column = bbk9588_nand_column_from_addr(nand);
+            bbk9588_nand_raise_ready(board);
+        }
+        break;
+    case 0x80:
+        bbk9588_nand_begin_program(nand);
+        break;
+    case 0x85:
+        break;
+    case 0x10:
+        bbk9588_nand_commit_program(nand);
+        nand->busy_reads = 1;
+        bbk9588_nand_bch_start(nand);
+        break;
+    case 0xd0:
+        bbk9588_nand_commit_erase(nand);
+        nand->busy_reads = 1;
+        bbk9588_nand_bch_start(nand);
+        nand->addr_count = 0;
+        nand->read_index = 0;
+        break;
+    case 0x70:
+        bbk9588_nand_fill_read(nand, status, sizeof(status));
+        break;
+    case 0x90:
+        bbk9588_nand_fill_read(nand, bbk9588_nand_id,
+                               sizeof(bbk9588_nand_id));
+        break;
+    case 0xff:
+        nand->busy_reads = 0;
+        bbk9588_nand_prepare_erased_page(nand);
+        break;
+    default:
+        break;
+    }
+}
+
+static void bbk9588_nand_address(Bbk9588NandState *nand, uint8_t value)
+{
+    if (nand->addr_count < ARRAY_SIZE(nand->addr)) {
+        nand->addr[nand->addr_count++] = value;
+    }
+    if (nand->cmd == 0x90 && nand->addr_count == 1 &&
+        nand->addr[0] == 0) {
+        bbk9588_nand_fill_read(nand, bbk9588_nand_id,
+                               sizeof(bbk9588_nand_id));
+    }
+    if (nand->cmd == 0x80 && nand->addr_count >= 5) {
+        nand->program_column = bbk9588_nand_column_from_addr(nand);
+        nand->program_page = bbk9588_nand_page_from_addr(nand);
+        nand->program_page_valid = true;
+    }
+    if (nand->cmd == 0x85 && nand->addr_count >= 5) {
+        nand->program_column = bbk9588_nand_column_from_addr(nand);
+        nand->program_page = bbk9588_nand_page_from_addr(nand);
+        nand->program_page_valid = true;
+    } else if (nand->cmd == 0x85 && nand->addr_count >= 2) {
+        nand->program_column = bbk9588_nand_column_from_addr(nand);
+    }
+}
+
+static void bbk9588_nand_write(Bbk9588NandState *nand, hwaddr offset,
+                               uint64_t value, unsigned size)
+{
+    switch (offset) {
+    case 0x00000:
+        bbk9588_nand_append_program_data(nand, value, size);
+        break;
+    case 0x08000:
+        if (size != 1) {
+            break;
+        }
+        bbk9588_nand_command(nand, value & 0xff);
+        break;
+    case 0x10000:
+        if (size != 1) {
+            break;
+        }
+        bbk9588_nand_address(nand, value & 0xff);
+        break;
+    default:
+        break;
+    }
+}
+
+static uint64_t bbk9588_nand_mmio_read(void *opaque,
+                                       hwaddr offset, unsigned size)
+{
+    Bbk9588NandState *nand = opaque;
+
+    return bbk9588_nand_read(nand, offset, size);
+}
+
+static void bbk9588_nand_mmio_write(void *opaque, hwaddr offset,
+                                    uint64_t value, unsigned size)
+{
+    Bbk9588NandState *nand = opaque;
+
+    bbk9588_nand_write(nand, offset, value, size);
+}
+
+static const MemoryRegionOps bbk9588_nand_ops = {
+    .read = bbk9588_nand_mmio_read,
+    .write = bbk9588_nand_mmio_write,
+    .endianness = DEVICE_LITTLE_ENDIAN,
+    .valid = {
+        .min_access_size = 1,
+        .max_access_size = 4,
+    },
+};
+
+static void bbk9588_nand_realize(DeviceState *dev, Error **errp)
+{
+    Bbk9588NandState *nand = BBK9588_NAND(dev);
+
+    memory_region_init_io(&nand->mmio, OBJECT(dev), &bbk9588_nand_ops, nand,
+                          "bbk9588.nand", 0x20000);
+    sysbus_init_mmio(SYS_BUS_DEVICE(dev), &nand->mmio);
+}
+
+static void bbk9588_create_nand_device(Bbk9588MachineState *board)
+{
+    DeviceState *dev = qdev_new(TYPE_BBK9588_NAND);
+    DriveInfo *dinfo = drive_get(IF_MTD, 0, 0);
+
+    if (dinfo) {
+        qdev_prop_set_drive_err(dev, "drive", blk_by_legacy_dinfo(dinfo),
+                                &error_fatal);
+    }
+    sysbus_realize(SYS_BUS_DEVICE(dev), &error_fatal);
+    sysbus_mmio_map(SYS_BUS_DEVICE(dev), 0, KSEG1_TO_PHYS(0xb8000000));
+    board->nand_dev = BBK9588_NAND(dev);
+    board->nand_dev->cmd = 0xff;
+    board->nand_dev->addr_count = 0;
+    board->nand_dev->busy_reads = 0;
+    board->nand_dev->bch_busy_reads = 0;
+    board->nand_dev->bch_status = BBK9588_BCH_STATUS_READY;
+    board->nand_dev->page_stride = BBK9588_NAND_STRIDE;
+    board->nand_dev->program_len = 0;
+    board->nand_dev->program_page = 0;
+    board->nand_dev->program_column = 0;
+    board->nand_dev->program_has_data = false;
+    board->nand_dev->program_page_valid = false;
+    board->nand_dev->last_oob_page_valid = false;
+    board->nand_dev->last_oob_page = 0;
+    bbk9588_nand_prepare_erased_page(board->nand_dev);
+}
+
+static void bbk9588_load_nand_image(Bbk9588MachineState *board)
+{
+    Bbk9588NandState *nand = board->nand_dev;
+    GError *err = NULL;
+    gchar *data = NULL;
+    gsize size = 0;
+    const char *image = board->nand_image;
+    BlockBackend *blk = nand ? nand->blk : NULL;
+
+    if (blk) {
+        int64_t blk_len;
+        uint64_t perm;
+        int ret;
+
+        perm = BLK_PERM_CONSISTENT_READ |
+               (blk_supports_write_perm(blk) ? BLK_PERM_WRITE : 0);
+        ret = blk_set_perm(blk, perm, BLK_PERM_ALL, &error_fatal);
+        if (ret < 0) {
+            exit(1);
+        }
+
+        blk_len = blk_getlength(blk);
+        if (blk_len <= 0) {
+            error_report("bbk9588: invalid MTD NAND image size");
+            exit(1);
+        }
+
+        data = g_malloc(blk_len);
+        if (blk_pread(blk, 0, blk_len, data, 0) < 0) {
+            error_report("bbk9588: could not read MTD NAND image");
+            g_free(data);
+            exit(1);
+        }
+        nand->data = (uint8_t *)data;
+        nand->size = blk_len;
+        nand->initial_data = g_memdup2(nand->data, nand->size);
+        nand->initial_size = nand->size;
+        bbk9588_nand_detect_geometry(nand);
+        info_report("bbk9588: loaded MTD NAND image (%" PRId64
+                    " bytes, page_stride=%u)",
+                    blk_len, nand->page_stride);
+        return;
+    }
+
+    if (!image) {
+        info_report("bbk9588: no nand-image supplied; CS0 returns erased data");
+        return;
+    }
+
+    if (!g_file_get_contents(image, &data, &size, &err)) {
+        error_report("bbk9588: could not load NAND image '%s': %s",
+                     image, err ? err->message : "unknown error");
+        g_clear_error(&err);
+        exit(1);
+    }
+
+    nand->data = (uint8_t *)data;
+    nand->size = size;
+    nand->initial_data = g_memdup2(nand->data, nand->size);
+    nand->initial_size = nand->size;
+    bbk9588_nand_detect_geometry(nand);
+    info_report("bbk9588: loaded NAND image '%s' (%" G_GSIZE_FORMAT
+                " bytes, page_stride=%u)",
+                image, size, nand->page_stride);
+}
+
+static void bbk9588_phys_write(hwaddr addr, const void *buf, hwaddr len)
+{
+    cpu_physical_memory_write(BBK9588_KSEG_TO_PHYS(addr), buf, len);
+}
+
+static void bbk9588_phys_write_u8(hwaddr addr, uint8_t value)
+{
+    bbk9588_phys_write(addr, &value, sizeof(value));
+}
+
+static void bbk9588_phys_write_le16(hwaddr addr, uint16_t value)
+{
+    uint8_t buf[2] = { value & 0xff, value >> 8 };
+
+    bbk9588_phys_write(addr, buf, sizeof(buf));
+}
+
+static void bbk9588_phys_write_le32(hwaddr addr, uint32_t value)
+{
+    uint8_t buf[4] = {
+        value & 0xff,
+        (value >> 8) & 0xff,
+        (value >> 16) & 0xff,
+        (value >> 24) & 0xff,
+    };
+
+    bbk9588_phys_write(addr, buf, sizeof(buf));
+}
+
+typedef struct Bbk9588Fat16Layout {
+    uint32_t nand_base_lba;
+    uint32_t volume_lba;
+    uint32_t bytes_per_sector;
+    uint32_t sectors_per_cluster;
+    uint32_t fat_lba;
+    uint32_t root_lba;
+    uint32_t root_dir_sectors;
+    uint32_t first_data_lba;
+    uint32_t total_sectors;
+} Bbk9588Fat16Layout;
+
+static uint16_t bbk9588_lduw_le(const uint8_t *p)
+{
+    return p[0] | (p[1] << 8);
+}
+
+static uint32_t bbk9588_ldl_le(const uint8_t *p)
+{
+    return p[0] | (p[1] << 8) | (p[2] << 16) | (p[3] << 24);
+}
+
+static void bbk9588_storage_trace_record(uint32_t logical,
+                                         uint32_t absolute,
+                                         uint32_t first_word)
+{
+    Bbk9588MachineState *board = bbk9588_active_board;
+    uint32_t seq;
+    uint32_t slot;
+    uint32_t base;
+
+    if (!board || !board->storage_trace_enabled) {
+        return;
+    }
+
+    seq = ++board->storage_trace_seq;
+    slot = (seq - 1) % BBK9588_STORAGE_TRACE_SLOTS;
+    base = BBK9588_STORAGE_TRACE_VA +
+           BBK9588_STORAGE_TRACE_HEADER_WORDS * 4u +
+           slot * BBK9588_STORAGE_TRACE_WORDS * 4u;
+    bbk9588_phys_write_le32(BBK9588_STORAGE_TRACE_VA,
+                            BBK9588_STORAGE_TRACE_MAGIC);
+    bbk9588_phys_write_le32(BBK9588_STORAGE_TRACE_VA + 4, seq);
+    bbk9588_phys_write_le32(BBK9588_STORAGE_TRACE_VA + 8, slot);
+    bbk9588_phys_write_le32(BBK9588_STORAGE_TRACE_VA + 12,
+                            BBK9588_STORAGE_TRACE_SLOTS);
+    bbk9588_phys_write_le32(base + 0, seq);
+    bbk9588_phys_write_le32(base + 4, logical);
+    bbk9588_phys_write_le32(base + 8, absolute);
+    bbk9588_phys_write_le32(base + 12, first_word);
+}
+
+static void bbk9588_msc_trace_record(uint32_t event,
+                                     uint32_t lba,
+                                     uint32_t dma_phys,
+                                     uint32_t bytes,
+                                     uint32_t cmd,
+                                     uint32_t arg,
+                                     uint32_t first_word)
+{
+    Bbk9588MachineState *board = bbk9588_active_board;
+    uint32_t seq;
+    uint32_t slot;
+    uint32_t base;
+    uint32_t pc = 0;
+
+    if (!board || !board->storage_trace_enabled) {
+        return;
+    }
+    if (board->cpu) {
+        pc = board->cpu->env.active_tc.PC & 0xffffffffu;
+    }
+
+    seq = ++board->msc_trace_seq;
+    slot = (seq - 1) % BBK9588_MSC_TRACE_SLOTS;
+    base = BBK9588_MSC_TRACE_VA +
+           BBK9588_MSC_TRACE_HEADER_WORDS * 4u +
+           slot * BBK9588_MSC_TRACE_WORDS * 4u;
+    bbk9588_phys_write_le32(BBK9588_MSC_TRACE_VA,
+                            BBK9588_MSC_TRACE_MAGIC);
+    bbk9588_phys_write_le32(BBK9588_MSC_TRACE_VA + 4, seq);
+    bbk9588_phys_write_le32(BBK9588_MSC_TRACE_VA + 8, slot);
+    bbk9588_phys_write_le32(BBK9588_MSC_TRACE_VA + 12,
+                            BBK9588_MSC_TRACE_SLOTS);
+    bbk9588_phys_write_le32(base + 0, seq);
+    bbk9588_phys_write_le32(base + 4, event);
+    bbk9588_phys_write_le32(base + 8, lba);
+    bbk9588_phys_write_le32(base + 12, dma_phys);
+    bbk9588_phys_write_le32(base + 16, bytes);
+    bbk9588_phys_write_le32(base + 20, cmd);
+    bbk9588_phys_write_le32(base + 24, arg);
+    bbk9588_phys_write_le32(base + 28, first_word);
+    bbk9588_phys_write_le32(base + 32, pc);
+}
+
+static void bbk9588_nand_target_trace_record(uint32_t event,
+                                             uint32_t a,
+                                             uint32_t b,
+                                             uint32_t c)
+{
+    Bbk9588MachineState *board = bbk9588_active_board;
+    uint32_t seq;
+    uint32_t slot;
+    uint32_t base;
+    uint32_t pc = 0;
+
+    if (!board || !board->storage_trace_enabled) {
+        return;
+    }
+    if (board->cpu) {
+        pc = board->cpu->env.active_tc.PC & 0xffffffffu;
+    }
+
+    seq = ++board->nand_target_trace_seq;
+    slot = (seq - 1) % BBK9588_NAND_TARGET_TRACE_SLOTS;
+    base = BBK9588_NAND_TARGET_TRACE_VA +
+           BBK9588_STORAGE_TRACE_HEADER_WORDS * 4u +
+           slot * BBK9588_NAND_TARGET_TRACE_WORDS * 4u;
+    bbk9588_phys_write_le32(BBK9588_NAND_TARGET_TRACE_VA,
+                            BBK9588_NAND_TARGET_TRACE_MAGIC);
+    bbk9588_phys_write_le32(BBK9588_NAND_TARGET_TRACE_VA + 4, seq);
+    bbk9588_phys_write_le32(BBK9588_NAND_TARGET_TRACE_VA + 8, slot);
+    bbk9588_phys_write_le32(BBK9588_NAND_TARGET_TRACE_VA + 12,
+                            BBK9588_NAND_TARGET_TRACE_SLOTS);
+    bbk9588_phys_write_le32(base + 0, seq);
+    bbk9588_phys_write_le32(base + 4, event);
+    bbk9588_phys_write_le32(base + 8, a);
+    bbk9588_phys_write_le32(base + 12, b);
+    bbk9588_phys_write_le32(base + 16, c);
+    bbk9588_phys_write_le32(base + 20, pc);
+}
+
+static bool bbk9588_fat16_layout_from_sector(const uint8_t *sector,
+                                             uint32_t absolute_sector,
+                                             Bbk9588Fat16Layout *layout)
+{
+    uint32_t hidden;
+    uint32_t reserved;
+    uint32_t fats;
+    uint32_t root_entries;
+    uint32_t sectors_per_fat;
+    uint32_t total_sectors;
+
+    if (sector[510] != 0x55 || sector[511] != 0xaa) {
+        return false;
+    }
+    if (memcmp(sector + 54, "FAT16", 5) != 0 &&
+        memcmp(sector + 82, "FAT16", 5) != 0) {
+        return false;
+    }
+
+    hidden = bbk9588_ldl_le(sector + 28);
+    if (absolute_sector < hidden) {
+        return false;
+    }
+    layout->bytes_per_sector = bbk9588_lduw_le(sector + 11);
+    layout->sectors_per_cluster = sector[13];
+    reserved = bbk9588_lduw_le(sector + 14);
+    fats = sector[16];
+    root_entries = bbk9588_lduw_le(sector + 17);
+    total_sectors = bbk9588_lduw_le(sector + 19);
+    if (total_sectors == 0) {
+        total_sectors = bbk9588_ldl_le(sector + 32);
+    }
+    sectors_per_fat = bbk9588_lduw_le(sector + 22);
+
+    if (layout->bytes_per_sector == 0 ||
+        layout->sectors_per_cluster == 0 ||
+        sectors_per_fat == 0 ||
+        total_sectors == 0) {
+        return false;
+    }
+
+    layout->nand_base_lba = absolute_sector - hidden;
+    layout->volume_lba = hidden;
+    layout->fat_lba = layout->volume_lba + reserved;
+    layout->root_dir_sectors =
+        (root_entries * 32 + layout->bytes_per_sector - 1) /
+        layout->bytes_per_sector;
+    layout->root_lba = layout->fat_lba + fats * sectors_per_fat;
+    layout->first_data_lba = layout->root_lba + layout->root_dir_sectors;
+    layout->total_sectors = total_sectors;
+    return true;
+}
+
+static bool bbk9588_find_fat16_layout(Bbk9588NandState *nand,
+                                      Bbk9588Fat16Layout *layout)
+{
+    const uint8_t *sources[2];
+    const uint32_t sectors_per_page = BBK9588_NAND_PAGE_SIZE / 512;
+    uint32_t stride = bbk9588_nand_page_stride(nand);
+    uint64_t pages;
+    const uint8_t *data;
+    gsize size;
+
+    if (!nand) {
+        return false;
+    }
+    data = nand->data;
+    size = nand->size;
+    if (!data || size < BBK9588_NAND_PAGE_SIZE) {
+        return false;
+    }
+    if (nand->fat16_layout_valid) {
+        layout->nand_base_lba = nand->fat16_nand_base_lba;
+        layout->volume_lba = nand->fat16_volume_lba;
+        layout->bytes_per_sector = nand->fat16_bytes_per_sector;
+        layout->sectors_per_cluster = nand->fat16_sectors_per_cluster;
+        layout->fat_lba = nand->fat16_fat_lba;
+        layout->root_lba = nand->fat16_root_lba;
+        layout->root_dir_sectors = nand->fat16_root_dir_sectors;
+        layout->first_data_lba = nand->fat16_first_data_lba;
+        layout->total_sectors = nand->fat16_total_sectors;
+        return true;
+    }
+
+    sources[0] = nand->initial_data ? nand->initial_data : data;
+    sources[1] = data;
+    for (unsigned source_index = 0; source_index < ARRAY_SIZE(sources);
+         source_index++) {
+        data = sources[source_index];
+        size = (data == nand->initial_data) ? nand->initial_size : nand->size;
+        if (!data || size < BBK9588_NAND_PAGE_SIZE) {
+            continue;
+        }
+        pages = size / stride;
+        for (uint64_t page = 0; page < pages; page++) {
+            uint64_t page_off = page * stride;
+
+            if (page_off + BBK9588_NAND_PAGE_SIZE > size) {
+                break;
+            }
+            for (uint32_t sector_in_page = 0;
+                 sector_in_page < sectors_per_page;
+                 sector_in_page++) {
+                const uint8_t *sector =
+                    data + page_off + sector_in_page * 512;
+                uint32_t absolute_sector = page * sectors_per_page +
+                                           sector_in_page;
+
+                if (bbk9588_fat16_layout_from_sector(sector, absolute_sector,
+                                                     layout)) {
+                    nand->fat16_layout_valid = true;
+                    nand->fat16_nand_base_lba = layout->nand_base_lba;
+                    nand->fat16_volume_lba = layout->volume_lba;
+                    nand->fat16_bytes_per_sector = layout->bytes_per_sector;
+                    nand->fat16_sectors_per_cluster =
+                        layout->sectors_per_cluster;
+                    nand->fat16_fat_lba = layout->fat_lba;
+                    nand->fat16_root_lba = layout->root_lba;
+                    nand->fat16_root_dir_sectors = layout->root_dir_sectors;
+                    nand->fat16_first_data_lba = layout->first_data_lba;
+                    nand->fat16_total_sectors = layout->total_sectors;
+                    return true;
+                }
+            }
+        }
+    }
+    return false;
+}
+
+static bool bbk9588_read_logical_sector(Bbk9588NandState *nand,
+                                        uint32_t lba,
+                                        uint8_t *sector)
+{
+    Bbk9588Fat16Layout layout;
+    uint64_t absolute_sector;
+    uint64_t page;
+    uint32_t stride;
+    uint32_t sector_in_page;
+    uint64_t offset;
+    const uint8_t *data;
+    gsize size;
+
+    if (!nand || !nand->data || !sector) {
+        return false;
+    }
+    if (!bbk9588_find_fat16_layout(nand, &layout)) {
+        return false;
+    }
+
+    stride = bbk9588_nand_page_stride(nand);
+    data = nand->data;
+    size = nand->size;
+    /*
+     * C200's FAT globals and MSC requests use the same logical disk LBA space
+     * as the partition boot sector: FAT is at hidden+reserved, root follows the
+     * FATs, and cluster data follows the root directory.  The NAND image stores
+     * that logical disk after the FTL prefix, so only the NAND base is added
+     * here.  Adding volume_lba again shifts every resource/cache read by the
+     * hidden-sector count and makes valid desktop resources look missing.
+     */
+    absolute_sector = (uint64_t)layout.nand_base_lba + lba;
+    page = absolute_sector / (BBK9588_NAND_PAGE_SIZE / 512);
+    sector_in_page = absolute_sector % (BBK9588_NAND_PAGE_SIZE / 512);
+    page = bbk9588_nand_translate_data_page(nand, (uint32_t)page, NULL);
+    offset = page * stride + sector_in_page * 512u;
+    if (offset + 512u > size) {
+        return false;
+    }
+    if (nand->initial_data &&
+        bbk9588_nand_data_region_is_blank(data, size, stride, page,
+                                          sector_in_page * 512u, 512u) &&
+        !bbk9588_nand_data_region_is_blank(nand->initial_data,
+                                           nand->initial_size, stride, page,
+                                           sector_in_page * 512u, 512u)) {
+        data = nand->initial_data;
+        size = nand->initial_size;
+        if (offset + 512u > size) {
+            return false;
+        }
+    }
+    memcpy(sector, data + offset, 512);
+    bbk9588_storage_trace_record(lba, (uint32_t)absolute_sector,
+                                 bbk9588_ldl_le(sector));
+    return true;
+}
+
+static bool bbk9588_write_logical_sector(Bbk9588NandState *nand,
+                                         uint32_t lba,
+                                         const uint8_t *sector)
+{
+    Bbk9588Fat16Layout layout;
+    uint64_t absolute_sector;
+    uint64_t page;
+    uint32_t stride;
+    uint32_t sector_in_page;
+    uint64_t offset;
+
+    if (!nand || !nand->data || !sector) {
+        return false;
+    }
+    if (!bbk9588_find_fat16_layout(nand, &layout)) {
+        return false;
+    }
+
+    stride = bbk9588_nand_page_stride(nand);
+    absolute_sector = (uint64_t)layout.nand_base_lba + lba;
+    page = absolute_sector / (BBK9588_NAND_PAGE_SIZE / 512);
+    sector_in_page = absolute_sector % (BBK9588_NAND_PAGE_SIZE / 512);
+    page = bbk9588_nand_translate_data_page(nand, (uint32_t)page, NULL);
+    offset = page * stride + sector_in_page * 512u;
+    if (offset + 512u > nand->size) {
+        return false;
+    }
+
+    memcpy(nand->data + offset, sector, 512);
+    bbk9588_nand_backend_update(nand, offset, 512);
+    bbk9588_storage_trace_record(BBK9588_STORAGE_TRACE_LOGICAL_WRITE | lba,
+                                 (uint32_t)absolute_sector,
+                                 bbk9588_ldl_le(sector));
+    if (lba == BBK9588_NAND_TARGET_LBA) {
+        bbk9588_nand_target_trace_record(
+            BBK9588_NAND_TARGET_EVENT_LOGICAL_WRITE, lba,
+            (uint32_t)absolute_sector, bbk9588_ldl_le(sector));
+    }
+    return true;
+}
+
+bool bbk9588_storage_read_fat_sector(uint32_t lba, uint8_t *sector)
+{
+    if (!bbk9588_active_board) {
+        return false;
+    }
+    return bbk9588_read_logical_sector(bbk9588_active_board->nand_dev, lba,
+                                       sector);
+}
+
+bool bbk9588_storage_read_cluster(uint32_t cluster, uint32_t sectors_per_read,
+                                  uint8_t *data, uint32_t *length)
+{
+    Bbk9588Fat16Layout layout;
+    uint32_t lba;
+
+    if (!bbk9588_active_board || !data || !length || cluster < 2 ||
+        cluster >= 0xfff8u) {
+        bbk9588_phys_write_le32(BBK9588_CLUSTER_TRACE_DETAIL_VA, 1);
+        bbk9588_phys_write_le32(BBK9588_CLUSTER_TRACE_DETAIL_VA + 4,
+                                cluster);
+        return false;
+    }
+    if (!bbk9588_find_fat16_layout(bbk9588_active_board->nand_dev, &layout)) {
+        bbk9588_phys_write_le32(BBK9588_CLUSTER_TRACE_DETAIL_VA, 2);
+        bbk9588_phys_write_le32(BBK9588_CLUSTER_TRACE_DETAIL_VA + 4,
+                                cluster);
+        return false;
+    }
+    if (sectors_per_read == 0 ||
+        sectors_per_read > layout.sectors_per_cluster) {
+        sectors_per_read = layout.sectors_per_cluster;
+    }
+    if (layout.bytes_per_sector != 512 ||
+        sectors_per_read == 0 ||
+        sectors_per_read > 0x100u) {
+        bbk9588_phys_write_le32(BBK9588_CLUSTER_TRACE_DETAIL_VA, 3);
+        bbk9588_phys_write_le32(BBK9588_CLUSTER_TRACE_DETAIL_VA + 4,
+                                layout.bytes_per_sector);
+        bbk9588_phys_write_le32(BBK9588_CLUSTER_TRACE_DETAIL_VA + 8,
+                                sectors_per_read);
+        return false;
+    }
+
+    lba = layout.first_data_lba +
+          (cluster - 2u) * layout.sectors_per_cluster;
+    for (uint32_t index = 0; index < sectors_per_read; index++) {
+        if (!bbk9588_read_logical_sector(bbk9588_active_board->nand_dev,
+                                         lba + index,
+                                         data + index * 512u)) {
+            bbk9588_phys_write_le32(BBK9588_CLUSTER_TRACE_DETAIL_VA, 4);
+            bbk9588_phys_write_le32(BBK9588_CLUSTER_TRACE_DETAIL_VA + 4,
+                                    lba + index);
+            bbk9588_phys_write_le32(BBK9588_CLUSTER_TRACE_DETAIL_VA + 8,
+                                    index);
+            return false;
+        }
+    }
+    *length = sectors_per_read * 512u;
+    bbk9588_phys_write_le32(BBK9588_CLUSTER_TRACE_DETAIL_VA, 5);
+    bbk9588_phys_write_le32(BBK9588_CLUSTER_TRACE_DETAIL_VA + 4, lba);
+    bbk9588_phys_write_le32(BBK9588_CLUSTER_TRACE_DETAIL_VA + 8, *length);
+    return true;
+}
+
+static bool bbk9588_is_usable_fat_dirent(const uint8_t *entry)
+{
+    uint8_t first = entry[0];
+    uint8_t attr = entry[0x0b];
+
+    if (first == 0x00 || first == 0xe5) {
+        return false;
+    }
+    if (attr == 0x0f || (attr & 0x08)) {
+        return false;
+    }
+    if ((entry[0] == '.' && entry[1] == ' ') ||
+        (entry[0] == '.' && entry[1] == '.' && entry[2] == ' ')) {
+        return false;
+    }
+    return true;
+}
+
+static void bbk9588_firmware_dirent_from_fat(const uint8_t *in, uint8_t *out)
+{
+    uint32_t cluster;
+
+    memset(out, 0, 0x20);
+    memcpy(out, in, 8);
+    memcpy(out + 8, in + 8, 3);
+    out[0x0b] = in[0x0b];
+    out[0x0c] = in[0x0c];
+    out[0x0d] = in[0x0d];
+    memcpy(out + 0x0e, in + 0x0e, 2);
+    memcpy(out + 0x10, in + 0x10, 2);
+    memcpy(out + 0x12, in + 0x12, 2);
+    cluster = ((uint32_t)bbk9588_lduw_le(in + 0x14) << 16) |
+              bbk9588_lduw_le(in + 0x1a);
+    out[0x14] = cluster & 0xff;
+    out[0x15] = (cluster >> 8) & 0xff;
+    out[0x16] = (cluster >> 16) & 0xff;
+    out[0x17] = (cluster >> 24) & 0xff;
+    memcpy(out + 0x18, in + 0x16, 2);
+    memcpy(out + 0x1a, in + 0x18, 2);
+    memcpy(out + 0x1c, in + 0x1c, 4);
+    if (out[0] == 5) {
+        out[0] = 0xe5;
+    }
+}
+
+static size_t bbk9588_short_component_from_dirent(const uint8_t *entry,
+                                                  uint8_t *out,
+                                                  size_t out_size)
+{
+    size_t len = 0;
+    int name_end = 8;
+    int ext_end = 11;
+
+    while (name_end > 0 && entry[name_end - 1] == ' ') {
+        name_end--;
+    }
+    while (ext_end > 8 && entry[ext_end - 1] == ' ') {
+        ext_end--;
+    }
+    for (int i = 0; i < name_end && len + 1 < out_size; i++) {
+        out[len++] = entry[i];
+    }
+    if (ext_end > 8 && len + 1 < out_size) {
+        out[len++] = '.';
+        for (int i = 8; i < ext_end && len + 1 < out_size; i++) {
+            out[len++] = entry[i];
+        }
+    }
+    if (out_size) {
+        out[len < out_size ? len : out_size - 1] = 0;
+    }
+    return len;
+}
+
+static uint8_t bbk9588_ascii_fold(uint8_t ch)
+{
+    if (ch >= 'A' && ch <= 'Z') {
+        return ch - 'A' + 'a';
+    }
+    return ch;
+}
+
+static bool bbk9588_component_equals(const uint8_t *a, size_t a_len,
+                                     const uint8_t *b, size_t b_len)
+{
+    if (a_len != b_len) {
+        return false;
+    }
+    for (size_t i = 0; i < a_len; i++) {
+        if (bbk9588_ascii_fold(a[i]) != bbk9588_ascii_fold(b[i])) {
+            return false;
+        }
+    }
+    return true;
+}
+
+static bool bbk9588_component_has_wildcard(const uint8_t *component,
+                                           size_t len)
+{
+    for (size_t i = 0; i < len; i++) {
+        if (component[i] == '*' || component[i] == '?') {
+            return true;
+        }
+    }
+    return false;
+}
+
+static bool bbk9588_dir_find_entry(const uint8_t *data, size_t size,
+                                   const uint8_t *component,
+                                   size_t component_len,
+                                   bool require_directory,
+                                   uint8_t *out_fat)
+{
+    bool wildcard = bbk9588_component_has_wildcard(component, component_len);
+
+    for (size_t off = 0; off + 0x20 <= size; off += 0x20) {
+        const uint8_t *entry = data + off;
+        uint8_t short_name[32];
+        size_t short_len;
+
+        if (entry[0] == 0x00) {
+            return false;
+        }
+        if (!bbk9588_is_usable_fat_dirent(entry)) {
+            continue;
+        }
+        if (require_directory && !(entry[0x0b] & 0x10)) {
+            continue;
+        }
+        short_len = bbk9588_short_component_from_dirent(entry, short_name,
+                                                        sizeof(short_name));
+        if (!wildcard &&
+            !bbk9588_component_equals(short_name, short_len, component,
+                                      component_len)) {
+            continue;
+        }
+        memcpy(out_fat, entry, 0x20);
+        return true;
+    }
+    return false;
+}
+
+static bool bbk9588_root_directory_data(Bbk9588NandState *nand,
+                                        const Bbk9588Fat16Layout *layout,
+                                        uint8_t **data,
+                                        size_t *size)
+{
+    size_t total = (size_t)layout->root_dir_sectors * 512u;
+
+    *data = g_malloc0(total);
+    *size = total;
+    for (uint32_t i = 0; i < layout->root_dir_sectors; i++) {
+        if (!bbk9588_read_logical_sector(nand, layout->root_lba + i,
+                                         *data + i * 512u)) {
+            g_free(*data);
+            *data = NULL;
+            *size = 0;
+            return false;
+        }
+    }
+    return true;
+}
+
+bool bbk9588_storage_first_dirent_for_pattern(const uint8_t *pattern,
+                                              size_t pattern_len,
+                                              uint8_t *out_firmware)
+{
+    Bbk9588Fat16Layout layout;
+    Bbk9588NandState *nand;
+    uint8_t *dir_data = NULL;
+    size_t dir_size = 0;
+    size_t pos = 0;
+    uint8_t found[0x20];
+    bool ok = false;
+
+    if (!bbk9588_active_board || !pattern || !out_firmware ||
+        pattern_len == 0) {
+        return false;
+    }
+    nand = bbk9588_active_board->nand_dev;
+    if (!bbk9588_find_fat16_layout(nand, &layout)) {
+        return false;
+    }
+    if (pattern_len >= 2 && pattern[1] == ':') {
+        pos = 2;
+    }
+    while (pos < pattern_len &&
+           (pattern[pos] == '\\' || pattern[pos] == '/')) {
+        pos++;
+    }
+    if (!bbk9588_root_directory_data(nand, &layout, &dir_data, &dir_size)) {
+        return false;
+    }
+
+    while (pos < pattern_len && pattern[pos] != 0) {
+        size_t start = pos;
+        size_t len;
+        bool last;
+
+        while (pos < pattern_len && pattern[pos] != 0 &&
+               pattern[pos] != '\\' && pattern[pos] != '/') {
+            pos++;
+        }
+        len = pos - start;
+        while (pos < pattern_len &&
+               (pattern[pos] == '\\' || pattern[pos] == '/')) {
+            pos++;
+        }
+        last = pos >= pattern_len || pattern[pos] == 0;
+        if (len == 0) {
+            continue;
+        }
+        if (!bbk9588_dir_find_entry(dir_data, dir_size, pattern + start, len,
+                                    !last, found)) {
+            goto out;
+        }
+        if (last) {
+            bbk9588_firmware_dirent_from_fat(found, out_firmware);
+            ok = true;
+            goto out;
+        }
+        g_free(dir_data);
+        dir_data = NULL;
+        dir_size = 0;
+        if (!(found[0x0b] & 0x10)) {
+            goto out;
+        }
+        uint32_t cluster = ((uint32_t)bbk9588_lduw_le(found + 0x14) << 16) |
+                           bbk9588_lduw_le(found + 0x1a);
+        uint32_t length = 0;
+        if (layout.bytes_per_sector != 512 ||
+            layout.sectors_per_cluster == 0 ||
+            layout.sectors_per_cluster > 0x100) {
+            goto out;
+        }
+        dir_size = (size_t)layout.sectors_per_cluster * 512u;
+        dir_data = g_malloc0(dir_size);
+        if (!bbk9588_storage_read_cluster(cluster, layout.sectors_per_cluster,
+                                          dir_data, &length)) {
+            goto out;
+        }
+        dir_size = MIN(dir_size, (size_t)length);
+    }
+
+out:
+    g_free(dir_data);
+    return ok;
+}
+
+bool bbk9588_storage_write_cluster(uint32_t cluster, uint32_t sectors_per_write,
+                                   const uint8_t *data, uint32_t *length)
+{
+    Bbk9588Fat16Layout layout;
+    uint32_t lba;
+
+    if (!bbk9588_active_board || !data || !length || cluster < 2 ||
+        cluster >= 0xfff8u) {
+        return false;
+    }
+    if (!bbk9588_find_fat16_layout(bbk9588_active_board->nand_dev, &layout)) {
+        return false;
+    }
+    if (sectors_per_write == 0 ||
+        sectors_per_write > layout.sectors_per_cluster) {
+        sectors_per_write = layout.sectors_per_cluster;
+    }
+    if (layout.bytes_per_sector != 512 ||
+        sectors_per_write == 0 ||
+        sectors_per_write > 0x100u) {
+        return false;
+    }
+
+    lba = layout.first_data_lba +
+          (cluster - 2u) * layout.sectors_per_cluster;
+    for (uint32_t index = 0; index < sectors_per_write; index++) {
+        if (!bbk9588_write_logical_sector(bbk9588_active_board->nand_dev,
+                                          lba + index,
+                                          data + index * 512u)) {
+            return false;
+        }
+    }
+    *length = sectors_per_write * 512u;
+    return true;
+}
+
+static void bbk9588_msc_complete_dma(Bbk9588MmioState *s)
+{
+    Bbk9588MachineState *board = s->board;
+    uint32_t dma_phys;
+    uint32_t words;
+    uint32_t bytes;
+    uint32_t sectors;
+    uint8_t *buf;
+    bool ok = true;
+
+    if (!board->msc_read_pending && !board->msc_write_pending) {
+        if (s->window->kind == BBK9588_MMIO_DMAC &&
+            s->window->kseg1_base == 0xb3020000) {
+            s->regs[0x08 / sizeof(uint32_t)] = 0;
+            s->regs[0x28 / sizeof(uint32_t)] = 0;
+        } else {
+            s->regs[0x10008 / sizeof(uint32_t)] = 0;
+            s->regs[0x10028 / sizeof(uint32_t)] = 0;
+        }
+        return;
+    }
+
+    if (s->window->kind == BBK9588_MMIO_DMAC &&
+        s->window->kseg1_base == 0xb3020000) {
+        if (board->msc_read_pending) {
+            dma_phys = s->regs[0x04 / sizeof(uint32_t)] & 0x1fffffff;
+            words = s->regs[0x08 / sizeof(uint32_t)];
+        } else {
+            dma_phys = s->regs[0x20 / sizeof(uint32_t)] & 0x1fffffff;
+            words = s->regs[0x28 / sizeof(uint32_t)];
+        }
+    } else {
+        if (board->msc_read_pending) {
+            dma_phys = s->regs[0x10004 / sizeof(uint32_t)] & 0x1fffffff;
+            words = s->regs[0x10008 / sizeof(uint32_t)];
+        } else {
+            dma_phys = s->regs[0x10020 / sizeof(uint32_t)] & 0x1fffffff;
+            words = s->regs[0x10028 / sizeof(uint32_t)];
+        }
+    }
+    bbk9588_storage_trace_record(
+        BBK9588_STORAGE_TRACE_DMAC_TRANSFER |
+        (board->msc_read_pending ? 1u : 2u),
+        words, dma_phys);
+    board->msc_last_dma_phys = dma_phys;
+    board->msc_last_dma_words = words;
+    board->msc_dma_complete_count++;
+    bytes = words * sizeof(uint32_t);
+    if (bytes == 0) {
+        board->msc_read_pending = false;
+        board->msc_write_pending = false;
+        return;
+    }
+    sectors = (bytes + 511u) / 512u;
+    if (sectors == 0 || sectors > 128) {
+        return;
+    }
+
+    buf = g_malloc0(sectors * 512u);
+    if (board->msc_read_pending) {
+        for (uint32_t i = 0; i < sectors; i++) {
+            if (!bbk9588_read_logical_sector(board->nand_dev,
+                                             board->msc_read_lba + i,
+                                             buf + i * 512u)) {
+                ok = false;
+                break;
+            }
+        }
+        bbk9588_msc_trace_record(BBK9588_MSC_TRACE_READ,
+                                 board->msc_read_lba, dma_phys, bytes,
+                                 board->msc_last_cmd, board->msc_last_arg,
+                                 ok ? bbk9588_ldl_le(buf) : 0xffffffffu);
+        if (board->storage_trace_enabled &&
+            board->msc_read_lba <= 0xa9b50u &&
+            board->msc_read_lba + sectors >= 0xa9b00u) {
+            error_report("bbk9588-msc-read lba=0x%08x sectors=%u dma=0x%08x "
+                         "bytes=%u cmd=0x%02x arg=0x%08x first=%08x "
+                         "at_icon=%02x%02x%02x%02x",
+                         board->msc_read_lba, sectors, dma_phys, bytes,
+                         board->msc_last_cmd, board->msc_last_arg,
+                         ok ? bbk9588_ldl_le(buf) : 0xffffffffu,
+                         buf[0xb8], buf[0xb9], buf[0xba], buf[0xbb]);
+        }
+        if (ok) {
+            cpu_physical_memory_write(dma_phys, buf, MIN(bytes, sectors * 512u));
+        }
+    } else {
+        cpu_physical_memory_read(dma_phys, buf, MIN(bytes, sectors * 512u));
+        bbk9588_msc_trace_record(BBK9588_MSC_TRACE_WRITE,
+                                 board->msc_write_lba, dma_phys, bytes,
+                                 board->msc_last_cmd, board->msc_last_arg,
+                                 bbk9588_ldl_le(buf));
+        for (uint32_t i = 0; i < sectors; i++) {
+            if (!bbk9588_write_logical_sector(board->nand_dev,
+                                              board->msc_write_lba + i,
+                                              buf + i * 512u)) {
+                ok = false;
+                break;
+            }
+        }
+    }
+    if (s->window->kind == BBK9588_MMIO_DMAC &&
+        s->window->kseg1_base == 0xb3020000) {
+        if (board->msc_read_pending) {
+            s->regs[0x08 / sizeof(uint32_t)] = 0;
+            s->regs[0x10 / sizeof(uint32_t)] =
+                (s->regs[0x10 / sizeof(uint32_t)] & ~0x00000001u) |
+                0x00000008u;
+        } else {
+            s->regs[0x28 / sizeof(uint32_t)] = 0;
+            s->regs[0x30 / sizeof(uint32_t)] =
+                (s->regs[0x30 / sizeof(uint32_t)] & ~0x00000001u) |
+                0x00000008u;
+        }
+    } else {
+        if (board->msc_read_pending) {
+            s->regs[0x10008 / sizeof(uint32_t)] = 0;
+            s->regs[0x10010 / sizeof(uint32_t)] =
+                (s->regs[0x10010 / sizeof(uint32_t)] & ~0x00000001u) |
+                0x00000008u;
+        } else {
+            s->regs[0x10028 / sizeof(uint32_t)] = 0;
+            s->regs[0x10030 / sizeof(uint32_t)] =
+                (s->regs[0x10030 / sizeof(uint32_t)] & ~0x00000001u) |
+                0x00000008u;
+        }
+    }
+    board->msc_read_pending = false;
+    board->msc_write_pending = false;
+    if (ok) {
+        board->msc_data_ready = true;
+    }
+    g_free(buf);
+}
+
+static bool bbk9588_dmac_audio_channel(hwaddr offset, unsigned *channel,
+                                        hwaddr *reg_offset)
+{
+    unsigned ch = offset / BBK9588_DMAC_CHANNEL_STRIDE;
+    hwaddr reg = (offset % BBK9588_DMAC_CHANNEL_STRIDE) & ~3u;
+
+    if ((ch == 2 || ch == 3) &&
+        (reg == BBK9588_DMAC_STATUS_OFF ||
+         reg == BBK9588_DMAC_CONFIG_OFF)) {
+        if (channel) {
+            *channel = ch;
+        }
+        if (reg_offset) {
+            *reg_offset = reg;
+        }
+        return true;
+    }
+    return false;
+}
+
+static void bbk9588_dmac_trace_sample(Bbk9588MmioState *s, uint32_t event,
+                                       unsigned channel, hwaddr offset,
+                                       uint32_t value)
+{
+    Bbk9588MachineState *board = s->board;
+    uint32_t base = BBK9588_DMAC_TRACE_VA;
+    uint32_t pc = 0;
+
+    if (!board || !bbk9588_guest_ram_va_valid(base,
+                                              BBK9588_DMAC_TRACE_WORDS * 4)) {
+        return;
+    }
+
+    if (board->cpu) {
+        pc = board->cpu->env.active_tc.PC & 0xffffffffu;
+    }
+
+    board->dmac_trace_seq++;
+    board->dmac_last_event = event;
+    board->dmac_last_channel = channel;
+    board->dmac_last_offset = offset;
+    board->dmac_last_value = value;
+
+    bbk9588_phys_write_le32(base + 0x00, BBK9588_DMAC_TRACE_MAGIC);
+    bbk9588_phys_write_le32(base + 0x04, board->dmac_trace_seq);
+    bbk9588_phys_write_le32(base + 0x08, event);
+    bbk9588_phys_write_le32(base + 0x0c, channel);
+    bbk9588_phys_write_le32(base + 0x10, offset);
+    bbk9588_phys_write_le32(base + 0x14, value);
+    bbk9588_phys_write_le32(base + 0x18, pc);
+    bbk9588_phys_write_le32(base + 0x1c, board->intc_pending_mask);
+    bbk9588_phys_write_le32(base + 0x20, board->intc_mask);
+    bbk9588_phys_write_le32(base + 0x24, s->regs[0x304 / sizeof(uint32_t)]);
+    bbk9588_phys_write_le32(base + 0x28, s->regs[0x50 / sizeof(uint32_t)]);
+    bbk9588_phys_write_le32(base + 0x2c, s->regs[0x54 / sizeof(uint32_t)]);
+    bbk9588_phys_write_le32(base + 0x30, s->regs[0x48 / sizeof(uint32_t)]);
+    bbk9588_phys_write_le32(base + 0x34, s->regs[0x70 / sizeof(uint32_t)]);
+    bbk9588_phys_write_le32(base + 0x38, s->regs[0x74 / sizeof(uint32_t)]);
+    bbk9588_phys_write_le32(base + 0x3c, s->regs[0x68 / sizeof(uint32_t)]);
+}
+
+static void bbk9588_dmac_sync_audio_irq(Bbk9588MmioState *s)
+{
+    Bbk9588MachineState *board = s->board;
+    bool pending = false;
+
+    for (unsigned ch = 2; ch <= 3; ch++) {
+        uint32_t bit = 1u << ch;
+        uint32_t status =
+            s->regs[(ch * BBK9588_DMAC_CHANNEL_STRIDE +
+                     BBK9588_DMAC_STATUS_OFF) / sizeof(uint32_t)];
+        uint32_t config =
+            s->regs[(ch * BBK9588_DMAC_CHANNEL_STRIDE +
+                     BBK9588_DMAC_CONFIG_OFF) / sizeof(uint32_t)];
+
+        if ((status & 0x00000008u) && (config & 0x00000002u)) {
+            s->regs[0x304 / sizeof(uint32_t)] |= bit;
+        } else if (!(status & 0x00000008u)) {
+            s->regs[0x304 / sizeof(uint32_t)] &= ~bit;
+        }
+    }
+    pending = (s->regs[0x304 / sizeof(uint32_t)] &
+               ((1u << 2) | (1u << 3))) != 0;
+
+    if (pending) {
+        board->intc_pending_mask |= 1u << BBK9588_DMAC_AUDIO_PARENT_IRQ;
+    } else {
+        board->intc_pending_mask &= ~(1u << BBK9588_DMAC_AUDIO_PARENT_IRQ);
+    }
+    bbk9588_dmac_trace_sample(s, 2, 0, 0, pending ? 1 : 0);
+    bbk9588_update_irq(board);
+}
+
+static void bbk9588_dmac_complete_audio_channel(Bbk9588MmioState *s,
+                                                unsigned channel)
+{
+    uint32_t status_index;
+    uint32_t count_index;
+
+    if (s->window->kind != BBK9588_MMIO_DMAC ||
+        s->window->kseg1_base != 0xb3020000 ||
+        (channel != 2 && channel != 3)) {
+        return;
+    }
+
+    status_index = (channel * BBK9588_DMAC_CHANNEL_STRIDE +
+                    BBK9588_DMAC_STATUS_OFF) / sizeof(uint32_t);
+    count_index = (channel * BBK9588_DMAC_CHANNEL_STRIDE +
+                   0x08u) / sizeof(uint32_t);
+    s->regs[count_index] = 0;
+    s->regs[status_index] |= 0x00000008u;
+    bbk9588_dmac_trace_sample(s, 3, channel,
+                              channel * BBK9588_DMAC_CHANNEL_STRIDE +
+                              BBK9588_DMAC_STATUS_OFF,
+                              s->regs[status_index]);
+    bbk9588_dmac_sync_audio_irq(s);
+}
