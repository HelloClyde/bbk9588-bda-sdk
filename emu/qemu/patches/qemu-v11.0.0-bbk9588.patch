+static bool bbk9588_nand_sector_looks_fat16(const uint8_t *sector,
+                                            uint32_t absolute_sector,
+                                            uint32_t *nand_base_lba)
+{
+    uint32_t hidden;
+    uint32_t bytes_per_sector;
+    uint32_t sectors_per_cluster;
+    uint32_t reserved;
+    uint32_t fats;
+    uint32_t root_entries;
+    uint32_t total_sectors;
+    uint32_t sectors_per_fat;
+
+    if (sector[510] != 0x55 || sector[511] != 0xaa) {
+        return false;
+    }
+    if (memcmp(sector + 54, "FAT16", 5) != 0 &&
+        memcmp(sector + 82, "FAT16", 5) != 0) {
+        return false;
+    }
+
+    hidden = bbk9588_ldl_le(sector + 28);
+    if (absolute_sector < hidden) {
+        return false;
+    }
+    bytes_per_sector = bbk9588_lduw_le(sector + 11);
+    sectors_per_cluster = sector[13];
+    reserved = bbk9588_lduw_le(sector + 14);
+    fats = sector[16];
+    root_entries = bbk9588_lduw_le(sector + 17);
+    total_sectors = bbk9588_lduw_le(sector + 19);
+    if (total_sectors == 0) {
+        total_sectors = bbk9588_ldl_le(sector + 32);
+    }
+    sectors_per_fat = bbk9588_lduw_le(sector + 22);
+
+    if (bytes_per_sector != 512 ||
+        sectors_per_cluster == 0 ||
+        (sectors_per_cluster & (sectors_per_cluster - 1)) != 0 ||
+        reserved == 0 ||
+        fats == 0 || fats > 2 ||
+        root_entries == 0 ||
+        total_sectors == 0 ||
+        sectors_per_fat == 0) {
+        return false;
+    }
+    if (nand_base_lba) {
+        *nand_base_lba = absolute_sector - hidden;
+    }
+    return true;
+}
+
+static int bbk9588_nand_geometry_score(Bbk9588NandState *nand,
+                                       uint32_t stride)
+{
+    const uint32_t sectors_per_page = BBK9588_NAND_PAGE_SIZE / 512;
+    uint64_t pages;
+    int best = -1;
+
+    if (!nand || !nand->data || stride < BBK9588_NAND_PAGE_SIZE) {
+        return -1;
+    }
+
+    pages = nand->size / stride;
+    for (uint64_t page = 0; page < pages; page++) {
+        uint64_t page_off = page * stride;
+
+        if (page_off + BBK9588_NAND_PAGE_SIZE > nand->size) {
+            break;
+        }
+        for (uint32_t sector_in_page = 0;
+             sector_in_page < sectors_per_page;
+             sector_in_page++) {
+            const uint8_t *sector =
+                nand->data + page_off + sector_in_page * 512u;
+            uint32_t absolute_sector =
+                (uint32_t)(page * sectors_per_page + sector_in_page);
+            uint32_t nand_base_lba = 0;
+            int score;
+
+            if (!bbk9588_nand_sector_looks_fat16(sector, absolute_sector,
+                                                 &nand_base_lba)) {
+                continue;
+            }
+
+            score = 10;
+            if ((nand_base_lba & 0xffu) == 0) {
+                score += 50;
+            }
+            if (page >= 0x1c00 && page <= 0x1d00) {
+                score += 20;
+            }
+            if (sector_in_page == 0) {
+                score += 5;
+            }
+            if (score > best) {
+                best = score;
+            }
+        }
+    }
+    return best;
+}
+
+static void bbk9588_nand_detect_geometry(Bbk9588NandState *nand)
+{
+    int stride_2112_score;
+    int stride_2048_score;
+
+    if (!nand || !nand->data || nand->size == 0) {
+        return;
+    }
+
+    stride_2112_score = bbk9588_nand_geometry_score(nand,
+                                                    BBK9588_NAND_STRIDE);
+    stride_2048_score = bbk9588_nand_geometry_score(nand,
+                                                    BBK9588_NAND_PAGE_SIZE);
+    if (stride_2112_score >= 0 || stride_2048_score >= 0) {
+        nand->page_stride =
+            stride_2112_score >= stride_2048_score ?
+            BBK9588_NAND_STRIDE : BBK9588_NAND_PAGE_SIZE;
+        nand->fat16_layout_valid = false;
+        return;
+    }
+
+    if (nand->size % BBK9588_NAND_STRIDE == 0) {
+        nand->page_stride = BBK9588_NAND_STRIDE;
+    } else if (nand->size % BBK9588_NAND_PAGE_SIZE == 0) {
+        nand->page_stride = BBK9588_NAND_PAGE_SIZE;
+    } else {
+        nand->page_stride = BBK9588_NAND_STRIDE;
+    }
+}
