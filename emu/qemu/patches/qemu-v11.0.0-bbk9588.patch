+static void bbk9588_sysctrl_raise_wake(Bbk9588MachineState *board,
+                                       bool gpio300_pulse)
+{
+    if (!bbk9588_sysctrl_wake_enabled(board)) {
+        return;
+    }
+    if (!board->sysctrl_wake_pending) {
+        board->sysctrl_wake_count++;
+        if (gpio300_pulse) {
+            board->gpio300_wake_pulse_available = true;
+        }
+    }
+    board->sysctrl_wake_pending = true;
+    board->intc_pending_mask |= 1u << 22;
+}
+
+static void bbk9588_sysctrl_sync_wake(Bbk9588MachineState *board)
+{
+    if (!bbk9588_sysctrl_wake_enabled(board)) {
+        board->sysctrl_wake_pending = false;
+    }
+}
