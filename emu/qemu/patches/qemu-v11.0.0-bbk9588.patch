+static void bbk9588_touch_trace_update(Bbk9588MachineState *board,
+                                        uint32_t reason)
+{
+    uint32_t pc = board->cpu ? board->cpu->env.active_tc.PC : 0;
+
+    if (!bbk9588_guest_ram_va_valid(BBK9588_TOUCH_TRACE_VA, 0x154)) {
+        return;
+    }
+
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x00,
+                            BBK9588_TOUCH_TRACE_MAGIC);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x04, 0);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x08, 0);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x0c, 0);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x10,
+                            board->touch_down ? 1u : 0u);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x14,
+                            board->touch_raw_x);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x18,
+                            board->touch_raw_y);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x1c,
+                            board->sadc_status_event);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x20,
+                            board->sadc_next_axis);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x24,
+                            board->intc_pending_mask);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x28, pc);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x2c, reason);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x30,
+                            board->sadc_conversion_events_remaining);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x34,
+                            board->sadc_control);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x38,
+                            board->sadc_last_read_offset);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x3c,
+                            board->sadc_last_read_value);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x40,
+                            board->sadc_last_write_offset);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x44,
+                            board->sadc_last_write_value);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x48,
+                            board->gpio_last_read_offset);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x4c,
+                            board->gpio_last_read_value);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x50,
+                            board->gpio_last_flag_offset);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x54,
+                            board->gpio_last_flag_value);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x58,
+                            board->intc_mask);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x5c,
+                            board->tcu_enabled_mask);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x60,
+                            board->tcu_pending_mask);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x64,
+                            board->tcu_compare[0]);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x68,
+                            board->tcu_compare[1]);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x6c,
+                            board->tcu_channel_period_ms[0]);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x70,
+                            board->tcu_channel_period_ms[1]);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x74,
+                            (uint32_t)board->tcu_deadline_ms[0]);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x78,
+                            (uint32_t)board->tcu_deadline_ms[1]);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x7c,
+                            board->intc_last_unmasked_pending);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x80,
+                            board->intc_last_level);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x84,
+                            board->intc_update_count);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x88,
+                            board->intc_last_cp0_status);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x8c,
+                            board->intc_last_cp0_cause);
+    if (board->cpu) {
+        CPUState *cs = CPU(board->cpu);
+
+        bbk9588_phys_write_le32(
+            BBK9588_TOUCH_TRACE_VA + 0x90,
+            board->cpu->env.bbk9588_irq_ip2_level ? 1u : 0u);
+        bbk9588_phys_write_le32(
+            BBK9588_TOUCH_TRACE_VA + 0x94,
+            (uint32_t)cs->interrupt_request);
+    }
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x98,
+                            board->intc_last_read_offset);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x9c,
+                            board->intc_last_read_value);
+    if (board->dmac_mmio) {
+        Bbk9588MmioState *dmac = board->dmac_mmio;
+
+        bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x144,
+                                dmac->regs[0x304 / sizeof(uint32_t)]);
+        bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x148,
+                                dmac->regs[0x70 / sizeof(uint32_t)]);
+        bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x14c,
+                                dmac->regs[0x74 / sizeof(uint32_t)]);
+        bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x150,
+                                dmac->regs[0x68 / sizeof(uint32_t)]);
+    }
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xa0,
+                            board->intc_last_write_offset);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xa4,
+                            board->intc_last_write_value);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xa8,
+                            board->intc_ack_count);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xac,
+                            board->intc_ack_tcu_count);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xb0,
+                            board->tcu_last_read_offset);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xb4,
+                            board->tcu_last_read_value);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xb8,
+                            board->tcu_last_write_offset);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xbc,
+                            board->tcu_last_write_value);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xc0,
+                            board->tcu_irq_raise_count);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xc4,
+                            board->irq24_raise_count);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xc8,
+                            board->msc_read_pending ? 1u : 0u);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xcc,
+                            board->msc_write_pending ? 1u : 0u);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xd0,
+                            board->msc_data_ready ? 1u : 0u);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xd4,
+                            board->msc_read_lba);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xd8,
+                            board->msc_write_lba);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xdc,
+                            board->msc_dma_complete_count);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xe0,
+                            board->msc_last_cmd);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xe4,
+                            board->msc_last_arg);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xe8,
+                            board->msc_last_dma_phys);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xec,
+                            board->msc_last_dma_words);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xf0,
+                            board->nand_ready_raise_count);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xf4,
+                            board->nand_page_read_count);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xf8,
+                            board->nand_program_count);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0xfc,
+                            board->nand_erase_count);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x100,
+                            board->nand_last_cmd);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x104,
+                            board->nand_last_page);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x108,
+                            board->nand_last_column);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x10c,
+                            board->nand_last_block);
+    if (board->nand_dev) {
+        bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x110,
+                                board->nand_dev->busy_reads);
+        bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x114,
+                                board->nand_dev->bch_busy_reads);
+        bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x118,
+                                board->nand_dev->addr_count);
+        bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x11c,
+                                board->gpio_flag_200);
+    }
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x120,
+                            board->sysctrl_wake_enable_20);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x124,
+                            board->sysctrl_wake_enable_24);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x128,
+                            board->extgpio_wake_enable_80);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x12c,
+                            board->sysctrl_wake_pending ? 1u : 0u);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x130,
+                            board->sysctrl_wake_count);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x134,
+                            board->tcu_irq_mask);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x138,
+                            board->tcu_compare[4]);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x13c,
+                            board->tcu_channel_period_ms[4]);
+    bbk9588_phys_write_le32(BBK9588_TOUCH_TRACE_VA + 0x140,
+                            (uint32_t)board->tcu_deadline_ms[4]);
+}
+
+static void bbk9588_sadc_sync_irq(Bbk9588MachineState *board)
+{
+    /*
+     * SADC reports both pen-down/sample-ready (0x14) and pen-up (0x08) as
+     * latched touch-controller events.  A browser tap often arrives as a fast
+     * down/up pair; clearing irq12 on pen-up loses the edge before firmware can
+     * leave WAIT and poll the SADC status register.
+     */
+    if (board->sadc_status_event & 0x1c) {
+        board->intc_pending_mask |= 1u << 12;
+    } else {
+        board->intc_pending_mask &= ~(1u << 12);
+    }
+    if (!bbk9588_try_wait_irq_service(board)) {
+        bbk9588_update_irq(board);
+    }
+}
+
+static void bbk9588_touch_set_state(Bbk9588MachineState *board,
+                                    uint16_t raw_x, uint16_t raw_y,
+                                    bool down)
+{
+    bool changed = board->touch_down != down ||
+                   board->touch_raw_x != raw_x ||
+                   board->touch_raw_y != raw_y;
+
+    board->touch_raw_x = raw_x;
+    board->touch_raw_y = raw_y;
+    board->touch_down = down;
+    if (down) {
+        board->sadc_conversion_events_remaining = 5;
+        board->sadc_status_event = (board->sadc_status_event & ~0x08) | 0x14;
+    } else {
+        board->sadc_conversion_events_remaining = 0;
+        board->sadc_status_event = (board->sadc_status_event & ~0x14) | 0x08;
+    }
+    board->sadc_next_axis = 0;
+    if (changed) {
+        bbk9588_sadc_sync_irq(board);
+    }
+    bbk9588_touch_sync_latch(board);
+    bbk9588_touch_trace_update(board, down ? 1u : 2u);
+}
+
+static uint32_t bbk9588_gpio_idle_level(hwaddr offset)
+{
+    switch (offset) {
+    case 0x100:
+        return 0x78040000;
+    case 0x200:
+        return 0x48000000;
+    case 0x300:
+        return 0x00200000;
+    default:
+        return 0;
+    }
+}
+
+static uint32_t bbk9588_gpio_level(Bbk9588MachineState *board, hwaddr offset,
+                                   uint32_t stored)
+{
+    uint32_t level = stored | bbk9588_gpio_idle_level(offset);
+
+    if (board->touch_down) {
+        if (offset == 0x100) {
+            level &= ~0x00040000;
+        } else if (offset == 0x200) {
+            level &= ~0x08000000;
+        }
+    }
+    switch (offset) {
+    case 0x100:
+        level &= ~board->key_gpio_down_100;
+        break;
+    case 0x200:
+        level &= ~board->key_gpio_down_200;
+        break;
+    case 0x300:
+        level &= ~board->key_gpio_down_300;
+        if (board->gpio300_wake_pulse_available) {
+            level |= 0x20000000u;
+            board->gpio300_wake_pulse_available = false;
+            board->sysctrl_wake_pending = false;
+            board->intc_pending_mask &= ~(1u << 22);
+        } else {
+            level &= ~0x20000000u;
+        }
+        break;
+    default:
+        break;
+    }
+    if (offset == 0x200 && board->nand_dev && board->nand_dev->busy_reads > 0) {
+        board->nand_dev->busy_reads--;
+        level &= ~0x40000000;
+    }
+    board->gpio_last_read_offset = (uint32_t)offset;
+    board->gpio_last_read_value = level;
+    bbk9588_touch_trace_update(board, 11u);
+    return level;
+}
+
+static uint32_t bbk9588_gpio_flag(Bbk9588MachineState *board, hwaddr offset,
+                                  uint32_t stored)
+{
+    switch (offset) {
+    case 0x180:
+        stored |= board->gpio_flag_100;
+        break;
+    case 0x280:
+        stored |= board->gpio_flag_200;
+        break;
+    case 0x380:
+        stored |= board->gpio_flag_300;
+        break;
+    default:
+        break;
+    }
+    board->gpio_last_flag_offset = (uint32_t)offset;
+    board->gpio_last_flag_value = stored;
+    bbk9588_touch_trace_update(board, 12u);
+    return stored;
+}
+
+static void bbk9588_gpio_sync_irq(Bbk9588MachineState *board, uint32_t flag,
+                                  int irq)
+{
+    if (irq < 0) {
+        return;
+    }
+    if (flag) {
+        board->intc_pending_mask |= 1u << irq;
+    } else {
+        board->intc_pending_mask &= ~(1u << irq);
+    }
+    bbk9588_update_irq(board);
+}
+
+static void bbk9588_gpio_clear_flag(Bbk9588MachineState *board, hwaddr offset,
+                                    uint32_t value)
+{
+    switch (offset) {
+    case 0x114:
+        board->gpio_flag_100 &= ~value;
+        bbk9588_gpio_sync_irq(board, board->gpio_flag_100, 27);
+        break;
+    case 0x214:
+        board->gpio_flag_200 &= ~value;
+        bbk9588_gpio_sync_irq(board, board->gpio_flag_200, 26);
+        break;
+    case 0x314:
+        board->gpio_flag_300 &= ~value;
+        bbk9588_gpio_sync_irq(board, board->gpio_flag_300, 25);
+        break;
+    default:
+        break;
+    }
+}
+
+static uint32_t bbk9588_sadc_read(Bbk9588MachineState *board, hwaddr offset)
+{
+    uint32_t value;
+    bool touch_sample_active = board->touch_down ||
+                               board->sadc_conversion_events_remaining > 0 ||
+                               (board->sadc_status_event & 0x04u) != 0;
+
+    switch (offset) {
+    case 0x00:
+        value = board->sadc_control;
+        break;
+    case 0x08:
+        /*
+         * The C200 touch ISR computes pending touch causes as
+         * status & ~control.  The real controller exposes the conversion
+         * enable/mask bit here, while pen-up and sample-ready remain status
+         * bits even if firmware writes nearby control bits.
+         */
+        value = board->sadc_control & ~0x04u;
+        break;
+    case 0x0c:
+        value = board->sadc_status_event;
+        break;
+    case 0x18:
+        if (touch_sample_active) {
+            value = board->touch_raw_x | (board->touch_raw_y << 16);
+        } else {
+            value = BBK9588_SADC_BATTERY_RAW |
+                    (BBK9588_SADC_BATTERY_RAW << 16);
+        }
+        break;
+    case 0x1c:
+    case 0x20:
+        if (touch_sample_active) {
+            if (board->sadc_next_axis++ & 1) {
+                value = board->touch_raw_y;
+            } else {
+                value = board->touch_raw_x;
+            }
+        } else {
+            value = BBK9588_SADC_BATTERY_RAW;
+        }
+        break;
+    default:
+        value = 0;
+        break;
+    }
+    board->sadc_last_read_offset = (uint32_t)offset;
+    board->sadc_last_read_value = value;
+    bbk9588_touch_trace_update(board, 9u);
+    return value;
+}
+
+static void bbk9588_sadc_write(Bbk9588MachineState *board, hwaddr offset,
+                               uint64_t value)
+{
+    board->sadc_last_write_offset = (uint32_t)offset;
+    board->sadc_last_write_value = (uint32_t)value;
+    if (offset == 0x00) {
+        board->sadc_control = (uint8_t)value;
+        if (value & 0x02) {
+            board->sadc_status_event |= 0x02;
+            bbk9588_sadc_sync_irq(board);
+        }
+        bbk9588_touch_trace_update(board, 8u);
+    } else if (offset == 0x0c) {
+        bool cleared_conversion = (value & 0x04) != 0;
+
+        board->sadc_status_event &= ~((uint8_t)value);
+        if (cleared_conversion && board->sadc_conversion_events_remaining > 0) {
+            board->sadc_conversion_events_remaining--;
+        }
+        if (board->touch_down &&
+            cleared_conversion &&
+            board->sadc_conversion_events_remaining > 0) {
+            board->sadc_status_event |= 0x04;
+        }
+        bbk9588_sadc_sync_irq(board);
+        bbk9588_touch_trace_update(board, 7u);
+    } else if (offset == 0x08) {
+        board->sadc_control = (uint8_t)value;
+        if (board->touch_down &&
+            (board->sadc_control & 0x10) &&
+            board->sadc_conversion_events_remaining > 0) {
+            board->sadc_status_event |= 0x04;
+        }
+        bbk9588_sadc_sync_irq(board);
+        bbk9588_touch_trace_update(board, 8u);
+    } else {
+        bbk9588_touch_trace_update(board, 10u);
+    }
+}
+
+static int bbk9588_uart_can_read(void *opaque)
+{
+    Bbk9588MachineState *board = opaque;
+
+    return BBK9588_UART_RX_FIFO_SIZE - board->uart_rx_len;
+}
+
+static void bbk9588_uart_update_rx_status(Bbk9588MachineState *board)
+{
+    if (board->uart_rx_len != 0) {
+        board->uart_status |= 0x01;
+    } else {
+        board->uart_status &= ~0x01u;
+    }
+}
+
+static void bbk9588_uart_read_backend(void *opaque, const uint8_t *buf,
+                                      int size)
+{
+    Bbk9588MachineState *board = opaque;
+
+    for (int i = 0; i < size && board->uart_rx_len < BBK9588_UART_RX_FIFO_SIZE;
+         i++) {
+        unsigned tail = (board->uart_rx_head + board->uart_rx_len) %
+                        BBK9588_UART_RX_FIFO_SIZE;
+
+        board->uart_rx_fifo[tail] = buf[i];
+        board->uart_rx_len++;
+    }
+    bbk9588_uart_update_rx_status(board);
+    bbk9588_uart_sync_irq(board);
+}
+
+static uint8_t bbk9588_uart_pop_rx(Bbk9588MachineState *board)
+{
+    uint8_t value = 0xff;
+
+    if (board->uart_rx_len != 0) {
+        value = board->uart_rx_fifo[board->uart_rx_head];
+        board->uart_rx_head = (board->uart_rx_head + 1) %
+                              BBK9588_UART_RX_FIFO_SIZE;
+        board->uart_rx_len--;
+    }
+    bbk9588_uart_update_rx_status(board);
+    bbk9588_uart_sync_irq(board);
+    qemu_chr_fe_accept_input(&board->uart_chr);
+    return value;
+}
+
+static void bbk9588_uart_clear_rx(Bbk9588MachineState *board)
+{
+    board->uart_rx_head = 0;
+    board->uart_rx_len = 0;
+    bbk9588_uart_update_rx_status(board);
+    bbk9588_uart_sync_irq(board);
+    qemu_chr_fe_accept_input(&board->uart_chr);
+}
+
+static uint32_t bbk9588_uart_read(Bbk9588MachineState *board,
+                                  Bbk9588MmioState *s,
+                                  hwaddr offset, unsigned size)
+{
+    uint32_t index = offset / sizeof(uint32_t);
+    unsigned shift = (offset & 3) * 8;
+    uint32_t value;
+
+    if (offset == 0x00 || offset == 0x04) {
+        return bbk9588_uart_pop_rx(board);
+    }
+    if (offset == 0x08) {
+        return board->uart_rx_len != 0 ? 0x04 : 0x01;
+    }
+    if (offset >= 0x14 && offset < 0x18) {
+        value = (s->regs[0x14 / sizeof(uint32_t)] |
+                 board->uart_status | 0x60u) >>
+                shift;
+        switch (size) {
+        case 1:
+            return value & 0xff;
+        case 2:
+            return value & 0xffff;
+        default:
+            return value;
+        }
+    }
+    value = s->regs[index] >> shift;
+    switch (size) {
+    case 1:
+        return value & 0xff;
+    case 2:
+        return value & 0xffff;
+    default:
+        return value;
+    }
+}
+
+static uint32_t bbk9588_udc_read(Bbk9588MachineState *board,
+                                 Bbk9588MmioState *s,
+                                 hwaddr offset, unsigned size)
+{
+    uint32_t index = offset / sizeof(uint32_t);
+    unsigned shift = (offset & 3) * 8;
+    uint32_t value;
+
+    /*
+     * Model the BBK USB device controller window at 0x13040000.  With no USB
+     * host attached, reads are idle/zero even if firmware previously wrote
+     * control bits.  Writes still
+     * update the backing register image for diagnostics, but disconnected UDC
+     * status/data reads should not echo those writes as hardware state.
+     *
+     * The C200 firmware also uses this BBK/JZ window as a small RTC/power
+     * status block: it polls halfword +2 bit 1 after WAIT and samples +4 as a
+     * free-running tick.  Expose those hardware bits so the scheduler can
+     * leave idle without firmware-side shortcuts.
+     */
+    if (offset >= 0x02 && offset < 0x04) {
+        value = 0x00000002u;
+    } else if (offset >= 0x04 && offset < 0x06) {
+        value = (uint32_t)(qemu_clock_get_ns(QEMU_CLOCK_VIRTUAL) /
+                           (NANOSECONDS_PER_SECOND / 64u)) & 0xffffu;
+    } else {
+        value = s->regs[index] >> shift;
+    }
+    switch (size) {
+    case 1:
+        return value & 0xff;
+    case 2:
+        return value & 0xffff;
+    default:
+        return value;
+    }
+}
+
+static void bbk9588_msc_prepare_response(Bbk9588MmioState *s)
+{
+    Bbk9588MachineState *board = s->board;
+    uint8_t cmd = s->regs[0x102c / sizeof(uint32_t)] & 0xff;
+    uint32_t arg = s->regs[0x1030 / sizeof(uint32_t)];
+
+    memset(s->msc_response, 0, sizeof(s->msc_response));
+    s->msc_response[0] = cmd;
+    s->msc_response_len = sizeof(s->msc_response);
+    s->msc_response_index = 0;
+    board->msc_last_cmd = cmd;
+    board->msc_last_arg = arg;
+    board->msc_data_ready = false;
+    s->regs[0x1028 / sizeof(uint32_t)] &= ~0x00000003u;
+    bbk9588_msc_trace_record(BBK9588_MSC_TRACE_CMD, arg >> 9, 0, 0,
+                             cmd, arg, 0);
+    if (s->window->kseg1_base == 0xb0020000 && (cmd == 0x11 || cmd == 0x12)) {
+        board->msc_read_lba = arg >> 9;
+        board->msc_read_pending = true;
+        board->msc_write_pending = false;
+    } else if (s->window->kseg1_base == 0xb0020000 &&
+               (cmd == 0x18 || cmd == 0x19)) {
+        board->msc_write_lba = arg >> 9;
+        board->msc_write_pending = true;
+        board->msc_read_pending = false;
+    }
+}
+
+static uint32_t bbk9588_msc_read_response(Bbk9588MmioState *s, unsigned size)
+{
+    uint32_t value = 0;
+
+    /*
+     * C200 loads halfwords from 0xb0021034 and stores the high byte first into
+     * its response buffer.  Return each FIFO pair as a big-endian halfword so
+     * the firmware sees the shifted response byte order.
+     */
+    if (size <= 1) {
+        if (s->msc_response_index < s->msc_response_len) {
+            value = s->msc_response[s->msc_response_index++];
+        }
+        return value;
+    }
+    for (unsigned i = 0; i < size; i += 2) {
+        uint32_t hi = 0;
+        uint32_t lo = 0;
+
+        if (s->msc_response_index < s->msc_response_len) {
+            hi = s->msc_response[s->msc_response_index++];
+        }
+        if (s->msc_response_index < s->msc_response_len) {
+            lo = s->msc_response[s->msc_response_index++];
+        }
+        value |= ((hi << 8) | lo) << (i * 8);
+    }
+    return value;
+}
+
+static void bbk9588_graphics_trace_write(Bbk9588MmioState *s, hwaddr offset,
+                                         uint64_t value, unsigned size)
+{
+    Bbk9588MachineState *board = s->board;
+
+    if (!board || !board->graphics_trace_enabled) {
+        return;
+    }
+    if (s->window->kind != BBK9588_MMIO_GRAPHICS) {
+        return;
+    }
+    if (board->graphics_trace_count++ >= 4096) {
+        return;
+    }
+    error_report(
+        "bbk9588-mmio[%u] win=0x%08" HWADDR_PRIx
+        " kind=%u off=0x%04" HWADDR_PRIx
+        " size=%u value=0x%08" PRIx64
+        " r0000=0x%08x r0004=0x%08x r0008=0x%08x r000c=0x%08x"
+        " r0010=0x%08x r0014=0x%08x r0018=0x%08x r001c=0x%08x"
+        " r0020=0x%08x r0024=0x%08x r0028=0x%08x r002c=0x%08x"
+        " r0030=0x%08x r0034=0x%08x r0038=0x%08x r003c=0x%08x"
+        " r0040=0x%08x r0044=0x%08x r0048=0x%08x r004c=0x%08x"
+        " r1000=0x%08x r1004=0x%08x r1008=0x%08x r100c=0x%08x"
+        " r1010=0x%08x r1014=0x%08x r1018=0x%08x r101c=0x%08x"
+        " r1020=0x%08x r1024=0x%08x r1028=0x%08x r102c=0x%08x"
+        " r1030=0x%08x r1034=0x%08x r1038=0x%08x r103c=0x%08x"
+        " lcd_desc=0x%08x lcd_fb=0x%08x",
+        board->graphics_trace_count - 1,
+        s->window->kseg1_base,
+        s->window->kind,
+        offset,
+        size,
+        value,
+        s->regs[0x0000 / sizeof(uint32_t)],
+        s->regs[0x0004 / sizeof(uint32_t)],
+        s->regs[0x0008 / sizeof(uint32_t)],
+        s->regs[0x000c / sizeof(uint32_t)],
+        s->regs[0x0010 / sizeof(uint32_t)],
+        s->regs[0x0014 / sizeof(uint32_t)],
+        s->regs[0x0018 / sizeof(uint32_t)],
+        s->regs[0x001c / sizeof(uint32_t)],
+        s->regs[0x0020 / sizeof(uint32_t)],
+        s->regs[0x0024 / sizeof(uint32_t)],
+        s->regs[0x0028 / sizeof(uint32_t)],
+        s->regs[0x002c / sizeof(uint32_t)],
+        s->regs[0x0030 / sizeof(uint32_t)],
+        s->regs[0x0034 / sizeof(uint32_t)],
+        s->regs[0x0038 / sizeof(uint32_t)],
+        s->regs[0x003c / sizeof(uint32_t)],
+        s->regs[0x0040 / sizeof(uint32_t)],
+        s->regs[0x0044 / sizeof(uint32_t)],
+        s->regs[0x0048 / sizeof(uint32_t)],
+        s->regs[0x004c / sizeof(uint32_t)],
+        s->regs[0x1000 / sizeof(uint32_t)],
+        s->regs[0x1004 / sizeof(uint32_t)],
+        s->regs[0x1008 / sizeof(uint32_t)],
+        s->regs[0x100c / sizeof(uint32_t)],
+        s->regs[0x1010 / sizeof(uint32_t)],
+        s->regs[0x1014 / sizeof(uint32_t)],
+        s->regs[0x1018 / sizeof(uint32_t)],
+        s->regs[0x101c / sizeof(uint32_t)],
+        s->regs[0x1020 / sizeof(uint32_t)],
+        s->regs[0x1024 / sizeof(uint32_t)],
+        s->regs[0x1028 / sizeof(uint32_t)],
+        s->regs[0x102c / sizeof(uint32_t)],
+        s->regs[0x1030 / sizeof(uint32_t)],
+        s->regs[0x1034 / sizeof(uint32_t)],
+        s->regs[0x1038 / sizeof(uint32_t)],
+        s->regs[0x103c / sizeof(uint32_t)],
+        board->lcd_dma_desc_va,
+        board->lcd_dma_frame_va);
+}
+
+static void bbk9588_uart_write(Bbk9588MachineState *board, hwaddr offset,
+                               uint64_t value)
+{
+    if ((offset == 0x00 || offset == 0x04) &&
+        qemu_chr_fe_backend_connected(&board->uart_chr)) {
+        uint8_t ch = value;
+
+        board->uart_status &= ~0x60u;
+        qemu_chr_fe_write_all(&board->uart_chr, &ch, 1);
+        board->uart_status |= 0x60u;
+    }
+    if (offset == 0x08 && (value & 0x02)) {
+        bbk9588_uart_clear_rx(board);
+    }
+}
+
+static uint32_t bbk9588_rtc_seconds(Bbk9588MachineState *board)
+{
+    int64_t now_ns = qemu_clock_get_ns(QEMU_CLOCK_VIRTUAL);
+    uint64_t elapsed = 0;
+
+    if (now_ns > board->rtc_base_ns) {
+        elapsed = (uint64_t)(now_ns - board->rtc_base_ns) / NANOSECONDS_PER_SECOND;
+    }
+    return board->rtc_base_seconds + (uint32_t)elapsed;
+}
+
+static uint64_t bbk9588_mmio_read(void *opaque, hwaddr offset, unsigned size)
+{
+    Bbk9588MmioState *s = opaque;
+    Bbk9588MachineState *board = s->board;
+    uint32_t index = offset / sizeof(uint32_t);
+    unsigned shift = (offset & 3) * 8;
+    uint32_t value;
+
+    switch (s->window->kind) {
+    case BBK9588_MMIO_SYSCTRL:
+        /*
+         * C200 calibrates its software delay loop from the clock control
+         * register at 0xb0000000.  A reset value of zero makes the firmware
+         * choose the smallest divider and inflates busy waits in the GUI
+         * resource loader.  Expose a conservative post-boot divider until the
+         * SYSCTRL clock tree is split into a fuller device.
+         */
+        if (offset == 0x00 && s->regs[index] == 0) {
+            return 0x00000008;
+        }
+        break;
+    case BBK9588_MMIO_EXTGPIO:
+        if (s->window->kseg1_base == 0xb3010000 && offset == 0x10008) {
+            bbk9588_msc_complete_dma(s);
+        }
+        if (s->window->kseg1_base == 0xb3010000 && offset == 0x10028) {
+            bbk9588_msc_complete_dma(s);
+        }
+        if (offset == 0x114) {
+            return bbk9588_nand_bch_read_status(board);
+        }
+        break;
+    case BBK9588_MMIO_DMAC:
+        if (s->window->kseg1_base == 0xb3020000 &&
+            (offset == 0x08 || offset == 0x28)) {
+            bbk9588_msc_complete_dma(s);
+        }
+        if (s->window->kseg1_base == 0xb3020000) {
+            unsigned channel;
+            hwaddr reg_offset;
+
+            if (bbk9588_dmac_audio_channel(offset, &channel, &reg_offset) &&
+                reg_offset == BBK9588_DMAC_STATUS_OFF &&
+                (s->regs[index] & 0x00000001u)) {
+                bbk9588_dmac_complete_audio_channel(s, channel);
+            }
+        }
+        break;
+    case BBK9588_MMIO_MISC:
+        if (s->window->kseg1_base == 0xb0070000) {
+            return bbk9588_sadc_read(board, offset);
+        }
+        break;
+    case BBK9588_MMIO_READY:
+        if (offset == 0x00) {
+            return s->regs[index] | board->ready_status;
+        }
+        if (offset == 0x04) {
+            return bbk9588_rtc_seconds(board);
+        }
+        if (offset == 0x08) {
+            return board->rtc_alarm_seconds;
+        }
+        if (offset == 0x34) {
+            return board->rtc_magic;
+        }
+        break;
+    case BBK9588_MMIO_INTC:
+        return bbk9588_intc_read(board, offset);
+        break;
+    case BBK9588_MMIO_GPIO:
+        if (offset == 0x100 || offset == 0x200 || offset == 0x300) {
+            return bbk9588_gpio_level(board, offset, s->regs[index]);
+        }
+        if (offset == 0x180 || offset == 0x280 || offset == 0x380) {
+            return bbk9588_gpio_flag(board, offset, s->regs[index]);
+        }
+        break;
+    case BBK9588_MMIO_GRAPHICS:
+        if (s->window->kseg1_base == 0xb0020000 && offset == 0x1004) {
+            return s->regs[index] | 0x00000800;
+        }
+        if (s->window->kseg1_base == 0xb0020000 && offset == 0x1034) {
+            return bbk9588_msc_read_response(s, size);
+        }
+        if (s->window->kseg1_base == 0xb0020000 && offset == 0x1028) {
+            return s->regs[index] | (board->msc_data_ready ? 0x00000003 : 0);
+        }
+        if (offset == 0x04 || offset == 0x1004) {
+            return s->regs[index] | board->graphics_status;
+        }
+        break;
+    case BBK9588_MMIO_UART:
+        return bbk9588_uart_read(board, s, offset, size);
+    case BBK9588_MMIO_UDC:
+        return bbk9588_udc_read(board, s, offset, size);
+    case BBK9588_MMIO_LCD:
+        if (offset == 0x0c) {
+            return board->lcd_status | board->lcd_irq_status |
+                   BBK9588_LCD_STATUS_READY;
+        }
+        break;
+    case BBK9588_MMIO_TCU:
+        /*
+         * Minimal TCU channel stub. Early firmware programs comparator/count
+         * registers around 0xb0002000 and then enables the channel through
+         * byte/halfword accesses at 0xb0002004/200c. Return a monotonically
+         * increasing count at the counter-like offsets so delay code observes
+         * time moving before the real JZ47xx timer/IRQ model exists.
+         */
+        if (offset == 0x14 || offset == 0x18 ||
+            offset == 0x24 || offset == 0x28 ||
+            offset == 0x34 || offset == 0x38) {
+            /*
+             * TESR/TECR/TFSR/TFCR/TMSR/TMCR are write-command registers.
+             * Firmware uses byte read/modify/write sequences when setting a
+             * single command bit; returning the previous command value makes
+             * later writes replay stale bits and can accidentally clear the
+             * running GUI timer channel.
+             */
+            board->tcu_last_read_offset = (uint32_t)offset;
+            board->tcu_last_read_value = 0;
+            return 0;
+        }
+        if (offset == 0x08) {
+            value = bbk9588_tcu_read_counter(s, 0);
+            board->tcu_last_read_offset = (uint32_t)offset;
+            board->tcu_last_read_value = value;
+            return value;
+        }
+        if (offset == 0x10) {
+            value = board->tcu_enabled_mask;
+            board->tcu_last_read_offset = (uint32_t)offset;
+            board->tcu_last_read_value = value;
+            return value;
+        }
+        if (offset == 0x20) {
+            value = board->tcu_pending_mask;
+            board->tcu_last_read_offset = (uint32_t)offset;
+            board->tcu_last_read_value = value;
+            return value;
+        }
+        if (offset == 0x30) {
+            value = board->tcu_irq_mask;
+            board->tcu_last_read_offset = (uint32_t)offset;
+            board->tcu_last_read_value = value;
+            return value;
+        }
+        if (offset >= 0x40 &&
+            offset < 0x40 + BBK9588_TCU_CHANNELS * 0x10) {
+            unsigned ch = (offset - 0x40) / 0x10;
+            hwaddr reg = (offset - 0x40) & 0x0f;
+
+            if (reg == 0x00 || reg == 0x04) {
+                value = board->tcu_compare[ch];
+                board->tcu_last_read_offset = (uint32_t)offset;
+                board->tcu_last_read_value = value;
+                return value;
+            }
+            if (reg == 0x08) {
+                value = bbk9588_tcu_read_counter(s, ch);
+                board->tcu_last_read_offset = (uint32_t)offset;
+                board->tcu_last_read_value = value;
+                return value;
+            }
+            if (reg == 0x0c) {
+                value = s->regs[index] | 0x00000001;
+                board->tcu_last_read_offset = (uint32_t)offset;
+                board->tcu_last_read_value = value;
+                return value;
+            }
+        }
+        if (offset == 0x04 || offset == 0x0c) {
+            value = s->regs[index] | 0x00000001;
+            board->tcu_last_read_offset = (uint32_t)offset;
+            board->tcu_last_read_value = value;
+            return value;
+        }
+        break;
+    }
+
+    value = s->regs[index] >> shift;
+    switch (size) {
+    case 1:
+        return value & 0xff;
+    case 2:
+        return value & 0xffff;
+    default:
+        return value;
+    }
+}
+
+static void bbk9588_mmio_write(void *opaque, hwaddr offset,
+                               uint64_t value, unsigned size)
+{
+    Bbk9588MmioState *s = opaque;
+    Bbk9588MachineState *board = s->board;
+    uint32_t index = offset / sizeof(uint32_t);
+    unsigned shift = (offset & 3) * 8;
+    uint32_t mask;
+    uint32_t old_reg;
+    uint32_t reg;
+
+    switch (size) {
+    case 1:
+        mask = 0xffu << shift;
+        break;
+    case 2:
+        mask = 0xffffu << shift;
+        break;
+    default:
+        mask = 0xffffffffu;
+        shift = 0;
+        break;
+    }
+    old_reg = s->regs[index];
+    reg = old_reg;
+    reg = (reg & ~mask) | (((uint32_t)value << shift) & mask);
+    s->regs[index] = reg;
+    bbk9588_graphics_trace_write(s, offset, value, size);
+    if (s->window->kind == BBK9588_MMIO_SYSCTRL) {
+        if (offset == 0x20) {
+            board->sysctrl_wake_enable_20 =
+                reg & (0x00000080u | 0x00000200u |
+                       0x00000800u | 0x00004000u);
+            bbk9588_sysctrl_sync_wake(board);
+            bbk9588_update_irq(board);
+        } else if (offset == 0x24) {
+            board->sysctrl_wake_enable_24 = reg & 0x00000080u;
+            bbk9588_sysctrl_sync_wake(board);
+            bbk9588_update_irq(board);
+        }
+    }
+    if (s->window->kind == BBK9588_MMIO_EXTGPIO &&
+        s->window->kseg1_base == 0xb3010000 &&
+        offset == 0x80) {
+        board->extgpio_wake_enable_80 = reg & 0x00040000u;
+        bbk9588_sysctrl_sync_wake(board);
+        bbk9588_update_irq(board);
+    }
+    if (s->window->kind == BBK9588_MMIO_READY) {
+        if (offset == 0x04) {
+            board->rtc_base_seconds = reg;
+            board->rtc_base_ns = qemu_clock_get_ns(QEMU_CLOCK_VIRTUAL);
+        } else if (offset == 0x08) {
+            board->rtc_alarm_seconds = reg;
+        } else if (offset == 0x34) {
+            board->rtc_magic = reg;
+        }
+    }
+    if (s->window->kind == BBK9588_MMIO_MISC &&
+        s->window->kseg1_base == 0xb0070000) {
+        bbk9588_sadc_write(board, offset, value);
+    }
+    if (s->window->kind == BBK9588_MMIO_INTC) {
+        bbk9588_intc_write(board, offset, value);
+    }
+    if (s->window->kind == BBK9588_MMIO_TCU) {
+        bbk9588_tcu_write(board, offset, value);
+    }
+    if (s->window->kind == BBK9588_MMIO_LCD) {
+        bbk9588_lcd_write(board, offset, value);
+    }
+    if (s->window->kind == BBK9588_MMIO_GPIO) {
+        bbk9588_gpio_clear_flag(board, offset, value);
+    }
+    if (s->window->kind == BBK9588_MMIO_LCD ||
+        (s->window->kind == BBK9588_MMIO_GRAPHICS &&
+         s->window->kseg1_base == 0xb3050000)) {
+        if (bbk9588_lcd_observe_mmio_write(board, offset, reg)) {
+            board->lcd_scanout_not_before_ms =
+                qemu_clock_get_ms(QEMU_CLOCK_REALTIME) +
+                board->lcd_refresh_period_ms;
+            bbk9588_lcd_schedule_vblank(board);
+        }
+    }
+    if (s->window->kind == BBK9588_MMIO_UART) {
+        bbk9588_uart_write(board, offset, value);
+    }
+    if (s->window->kind == BBK9588_MMIO_EXTGPIO &&
+        s->window->kseg1_base == 0xb3010000 &&
+        offset == 0x114) {
+        bbk9588_nand_bch_ack_status(board, reg);
+    }
+    if (s->window->kind == BBK9588_MMIO_EXTGPIO &&
+        s->window->kseg1_base == 0xb3010000 &&
+        (offset == 0x10010 || offset == 0x10030) &&
+        (reg & 0x80000001u)) {
+        bbk9588_msc_complete_dma(s);
+    }
+    if (s->window->kind == BBK9588_MMIO_DMAC &&
+        s->window->kseg1_base == 0xb3020000 &&
+        (offset == 0x10 || offset == 0x30) &&
+        (reg & 0x80000001u)) {
+        bbk9588_msc_complete_dma(s);
+    }
+    if (s->window->kind == BBK9588_MMIO_DMAC &&
+        s->window->kseg1_base == 0xb3020000) {
+        unsigned channel;
+
+        hwaddr reg_offset;
+
+        if (bbk9588_dmac_audio_channel(offset, &channel, &reg_offset)) {
+            bbk9588_dmac_trace_sample(s, 1, channel, offset, reg);
+            if (reg_offset == BBK9588_DMAC_STATUS_OFF &&
+                (reg & 0x00000001u) && !(old_reg & 0x00000001u)) {
+                bbk9588_dmac_complete_audio_channel(s, channel);
+            } else if (reg_offset == BBK9588_DMAC_CONFIG_OFF &&
+                       (reg & 0x00000002u)) {
+                uint32_t status_index =
+                    (channel * BBK9588_DMAC_CHANNEL_STRIDE +
+                     BBK9588_DMAC_STATUS_OFF) / sizeof(uint32_t);
+
+                if ((s->regs[status_index] & 0x00000001u) &&
+                    !(s->regs[status_index] & 0x00000008u)) {
+                    bbk9588_dmac_complete_audio_channel(s, channel);
+                } else {
+                    bbk9588_dmac_sync_audio_irq(s);
+                }
+            } else {
+                bbk9588_dmac_sync_audio_irq(s);
+            }
+        }
+    }
+    if (s->window->kind == BBK9588_MMIO_GRAPHICS &&
+        s->window->kseg1_base == 0xb0020000 &&
+        offset == 0x1000 && (value & 0xffffu) == 6) {
+        bbk9588_msc_prepare_response(s);
+        s->regs[0x1004 / sizeof(uint32_t)] =
+            (s->regs[0x1004 / sizeof(uint32_t)] & ~0x00000100u) |
+            0x00000800u;
+    }
+    if (s->window->kind == BBK9588_MMIO_GRAPHICS &&
+        s->window->kseg1_base == 0xb0020000 &&
+        offset == 0x1028 && (value & 0x03u)) {
+        s->regs[index] &= ~(value & 0x03u);
+        if ((s->regs[index] & 0x03u) == 0) {
+            board->msc_data_ready = false;
+        }
+    }
+}
+
+static const MemoryRegionOps bbk9588_mmio_ops = {
+    .read = bbk9588_mmio_read,
+    .write = bbk9588_mmio_write,
+    .endianness = DEVICE_LITTLE_ENDIAN,
+    .valid = {
+        .min_access_size = 1,
+        .max_access_size = 4,
+    },
+};
